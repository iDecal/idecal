---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Các từ khóa chuẩn SEO cho iDecal
const title = "iDecal | Giải Pháp Decal Dán Kính & Phim Cách Nhiệt Chuyên Nghiệp";
const description = "Chuyên thi công decal dán kính văn phòng, phim cách nhiệt, decal mờ 3D và cắt chữ logo tại TP.HCM. Thiết kế độc quyền - Thi công tận tâm.";
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <section class="relative py-20 bg-primary-900 text-white overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center relative z-10">
        <div>
          <h1 class="text-3xl md:text-4xl font-black mb-6 uppercase leading-tight">
            Nâng Tầm Không Gian Với <br/><span class="text-accent-500">Giải Pháp Decal Trọn Gói</span>
          </h1>
          <p class="text-primary-100 text-lg mb-8 leading-relaxed max-w-xl">
            Từ thiết kế độc quyền đến thi công chuyên nghiệp. iDecal đồng hành cùng doanh nghiệp kiến tạo không gian làm việc đẳng cấp.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="tel:086677040" class="bg-accent-500 text-primary-900 px-8 py-4 rounded-xl font-black hover:bg-white transition-all shadow-lg">GỌI TƯ VẤN NGAY</a>
            <a href="#services" class="border border-white/30 px-8 py-4 rounded-xl font-bold hover:bg-white/10 transition-all">XEM DỊCH VỤ</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
        <div class="relative">
          <img src="/images/about-idecal.webp" alt="Về iDecal" class="rounded-[30px] shadow-xl w-full h-[400px] object-cover border-4 border-white" />
        </div>
        <div>
          <h2 class="text-2xl md:text-3xl font-black text-primary-900 mb-6 uppercase">Chuyên gia Decal & Phim cách nhiệt</h2>
          <p class="text-gray-600 mb-6 text-base leading-relaxed">
            Với hơn nhiều năm kinh nghiệm, <strong>iDecal</strong> tự hào cung cấp các giải pháp trang trí và chống nóng toàn diện. Chúng tôi không chỉ dán decal, chúng tôi kiến tạo không gian riêng tư và chuyên nghiệp cho văn phòng của bạn.
          </p>
          <a href="/gioi-thieu" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg font-bold text-sm hover:bg-primary-700 transition-all uppercase tracking-wide">
            Tìm hiểu về iDecal
          </a>
        </div>
      </div>
    </section>

    <section id="services" class="py-20 bg-primary-50">
      <div class="max-w-7xl mx-auto px-6 text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-black text-primary-900 uppercase">Dịch vụ thế mạnh</h2>
        <div class="w-20 h-1 bg-accent-500 mx-auto mt-4"></div>
      </div>

      <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { title: "Decal mờ 3D", img: "decal-mo-3d.webp", desc: "Thiết kế vân nổi sống động, tạo chiều sâu và sự riêng tư tinh tế cho kính." },
          { title: "Phim cách nhiệt", img: "phim-cach-nhiet.webp", desc: "Chống nắng, cách nhiệt 80%, bảo vệ sức khỏe và nội thất văn phòng." },
          { title: "Decal cắt chữ", img: "decal-cat-chu.webp", desc: "Cắt chữ, Logo nhận diện thương hiệu sắc nét bằng máy CNC hiện đại." },
          { title: "Phim dán nội thất", img: "phim-dan-noi-that.webp", desc: "Làm mới tủ, bàn, cửa với film vân gỗ, đá tự nhiên sang trọng." },
          { title: "Decal quảng cáo", img: "decal-quang-cao.webp", desc: "In ấn khổ lớn trên chất liệu PP, Vinyl bền màu cho mọi chiến dịch." },
          { title: "Decal văn phòng", img: "decal-van-phong.webp", desc: "Giải pháp che mờ, kẻ line trang trí chuyên nghiệp cho nơi làm việc." }
        ].map((item) => (
          <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all group overflow-hidden border border-primary-100">
            <div class="aspect-video overflow-hidden">
              <img src={`/images/${item.img}`} alt={item.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-black mb-3 text-primary-800">{item.title}</h3>
              <p class="text-gray-500 text-sm mb-4 leading-relaxed">{item.desc}</p>
              <a href="#" class="text-primary-600 font-bold text-sm flex items-center gap-2">Chi tiết <span>→</span></a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-3 gap-8">
          <div class="p-8 bg-primary-50 rounded-[30px] border border-primary-100 group">
            <div class="text-primary-600 mb-6 group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
            </div>
            <h3 class="text-xl font-black mb-3 text-primary-900 uppercase">Thiết kế độc quyền</h3>
            <p class="text-sm text-gray-500">Hỗ trợ chỉnh sửa mẫu, chèn logo chuẩn xác theo yêu cầu thương hiệu.</p>
          </div>
          <div class="p-8 bg-primary-50 rounded-[30px] border border-primary-100 group">
            <div class="text-primary-600 mb-6 group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
            </div>
            <h3 class="text-xl font-black mb-3 text-primary-900 uppercase">In ấn sắc nét</h3>
            <p class="text-sm text-gray-500">Hệ thống máy in Eco-Solvent hiện đại cho màu sắc trung thực, bền bỉ.</p>
          </div>
          <div class="p-8 bg-primary-50 rounded-[30px] border border-primary-100 group">
            <div class="text-primary-600 mb-6 group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" /></svg>
            </div>
            <h3 class="text-xl font-black mb-3 text-primary-900 uppercase">Thi công tận tâm</h3>
            <p class="text-sm text-gray-500">Đội ngũ thợ tay nghề cao, đảm bảo sạch sẽ, thẩm mỹ từng chi tiết.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-primary-50">
      <div class="max-w-4xl mx-auto px-6">
        <div class="bg-white p-10 md:p-14 rounded-[50px] shadow-xl border border-primary-100 text-center relative overflow-hidden">
          <h3 class="text-xl md:text-2xl font-black text-primary-900 mb-4 italic underline decoration-accent-500 underline-offset-8 uppercase">
            Tư vấn từ chuyên gia iDecal
          </h3>
          <p class="text-gray-600 mb-8 text-sm md:text-base">
            Khảo sát tận nơi và thiết kế mẫu demo miễn phí tại TP.HCM.
          </p>
          <div class="bg-primary-50/50 p-6 rounded-2xl border border-dashed border-primary-200 mb-8 inline-block w-full max-w-sm">
             <p class="text-[10px] text-primary-400 font-bold uppercase mb-1">Hotline 24/7</p>
             <a href="tel:086677040" class="text-3xl md:text-4xl font-black text-primary-600 tracking-tighter">0866-77040</a>
          </div>
          <a href="/lien-he" class="block w-full max-w-xs mx-auto bg-primary-600 text-white font-black py-4 rounded-xl hover:bg-primary-700 transition-all text-base uppercase shadow-lg">
            ĐẶT THIẾT KẾ MẪU
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
