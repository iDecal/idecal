---
import Layout from '../layouts/Layout.astro';

const locations = [
  { region: "Miền Nam", cities: ["TP. Hồ Chí Minh", "Bình Dương", "Đồng Nai", "Long An", "Bà Rịa - Vũng Tàu"] },
  { region: "Miền Trung", cities: ["Nha Trang", "Quy Nhơn", "Đà Nẵng"] },
  { region: "Miền Bắc", cities: ["Thủ đô Hà Nội"] }
];
---

<Layout title="Liên hệ iDecal | Tư vấn thi công toàn quốc">
  <main class="bg-white pt-24 pb-20">
    <div class="max-w-7xl mx-auto px-6">
      
      <div class="mb-16">
        <h1 class="text-4xl md:text-6xl font-bold text-secondary mb-6 ">Liên hệ <span class="text-primary">iDecal.</span></h1>
        <p class="text-slate-500 max-w-2xl leading-relaxed">
          Chúng tôi sẵn sàng hỗ trợ khảo sát, đo đạc mẫu và báo giá tận nơi hoàn toàn miễn phí. Đội ngũ kỹ thuật có mặt nhanh chóng tại các khu vực trọng điểm.
        </p>
      </div>

      <div class="grid lg:grid-cols-[1fr_450px] gap-16 items-start">
        
        <div class="space-y-12">
          <div>
            <h2 class="text-secondary font-bold text-xl mb-8 uppercase tracking-widest border-b pb-4">Khu vực phục vụ</h2>
            <div class="grid sm:grid-cols-2 gap-8">
              {locations.map((loc) => (
                <div>
                  <h3 class="text-primary font-black text-xs uppercase mb-4 tracking-tighter">{loc.region}</h3>
                  <ul class="space-y-3">
                    {loc.cities.map(city => (
                      <li class="flex items-center gap-3 text-secondary font-bold group">
                        <span class="w-1.5 h-1.5 bg-primary rounded-full group-hover:scale-150 transition-transform"></span>
                        {city}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-slate-50 p-8 rounded-[2.5rem] border border-slate-100 flex flex-col md:flex-row gap-8 items-center">
            <div class="flex-1">
              <p class="text-slate-400 text-[10px] uppercase font-bold mb-1">Hotline hỗ trợ 24/7</p>
              <a href="tel:0900000000" class="text-3xl font-black text-secondary hover:text-primary transition-colors">090.xxx.xxxx</a>
            </div>
            <div class="flex-1 border-t md:border-t-0 md:border-l border-slate-200 pt-6 md:pt-0 md:pl-8">
              <p class="text-slate-400 text-[10px] uppercase font-bold mb-1">Email báo giá</p>
              <p class="text-secondary font-bold">contact@idecal.vn</p>
            </div>
          </div>
        </div>

        <div class="bg-white border-2 border-slate-50 p-8 md:p-10 rounded-[3rem] shadow-2xl shadow-slate-200/50 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-full -z-0"></div>
          
          <h3 class="text-2xl font-bold text-secondary mb-2 relative z-10">Gửi yêu cầu</h3>
          <p class="text-slate-400 text-sm mb-8 relative z-10 lowercase">nhận báo giá chi tiết sau 15 phút</p>

          <form class="space-y-5 relative z-10">
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase mb-2 ml-1">Họ và tên</label>
              <input type="text" placeholder="Anh Lê" class="w-full bg-slate-50 border-none rounded-2xl px-5 py-4 text-secondary focus:ring-2 focus:ring-primary outline-none transition-all" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase mb-2 ml-1">Số điện thoại</label>
              <input type="tel" placeholder="090..." class="w-full bg-slate-50 border-none rounded-2xl px-5 py-4 text-secondary focus:ring-2 focus:ring-primary outline-none transition-all" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase mb-2 ml-1">Địa chỉ thi công</label>
              <input type="text" placeholder="Ví dụ: Quận 1, TPHCM" class="w-full bg-slate-50 border-none rounded-2xl px-5 py-4 text-secondary focus:ring-2 focus:ring-primary outline-none transition-all" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase mb-2 ml-1">Ghi chú yêu cầu</label>
              <textarea rows="3" placeholder="Dán decal mờ văn phòng..." class="w-full bg-slate-50 border-none rounded-2xl px-5 py-4 text-secondary focus:ring-2 focus:ring-primary outline-none transition-all resize-none"></textarea>
            </div>
            <button class="w-full bg-secondary hover:bg-primary text-white font-black py-5 rounded-2xl shadow-xl shadow-secondary/20 transition-all uppercase tracking-widest text-sm">
              Gửi yêu cầu báo giá
            </button>
          </form>
        </div>

      </div>
    </div>
  </main>
</Layout>
