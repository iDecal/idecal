---
import Layout from '../layouts/Layout.astro';

const title = "Liên hệ iDecal | Tư vấn khảo sát dán decal tận nơi miễn phí";
const description = "Kết nối với đội ngũ iDecal để nhận tư vấn, thiết kế mẫu độc quyền và khảo sát đo đạc tận nơi hoàn toàn miễn phí tại TP.HCM, Bình Dương và các khu vực lân cận.";
---

<Layout title={title} description={description}>
  <main class="bg-white">
    <section class="bg-secondary text-white py-16">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <h1 class="text-4xl md:text-5xl font-heading font-black mb-4">LIÊN HỆ VỚI CHÚNG TÔI</h1>
        <p class="text-gray-400 max-w-2xl mx-auto text-lg">
          iDecal luôn sẵn sàng lắng nghe và hỗ trợ bạn 24/7. Đừng ngần ngại liên hệ để có giải pháp trang trí kính tốt nhất.
        </p>
      </div>
    </section>

    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16">
          
          <div>
            <h2 class="text-3xl font-heading font-black text-secondary mb-8">Thông tin iDecal</h2>
            
            <div class="space-y-8">
              <div class="flex gap-6">
                <div class="bg-primary/10 p-4 rounded-2xl h-fit">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-gray-500 font-bold uppercase text-xs tracking-widest mb-1">Hotline & Zalo</h4>
                  <a href="tel:0866077040" class="text-2xl font-black text-secondary hover:text-primary transition-colors">0866.077.040</a>
                  <p class="text-gray-500 text-sm mt-1">Tư vấn kỹ thuật và báo giá 24/7</p>
                </div>
              </div>

              <div class="flex gap-6">
                <div class="bg-primary/10 p-4 rounded-2xl h-fit">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-gray-500 font-bold uppercase text-xs tracking-widest mb-1">Khu vực phục vụ</h4>
                  <p class="text-xl font-bold text-secondary">TP. Hồ Chí Minh & Bình Dương</p>
                  <p class="text-gray-500 text-sm mt-1">Khảo sát tận nhà tại Thủ Đức, Quận 1, Quận 3, Thuận An...</p>
                </div>
              </div>

              <div class="flex gap-6">
                <div class="bg-primary/10 p-4 rounded-2xl h-fit">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-gray-500 font-bold uppercase text-xs tracking-widest mb-1">Email gửi mẫu thiết kế</h4>
                  <p class="text-xl font-bold text-secondary">contact@idecal.vn</p>
                </div>
              </div>
            </div>

            <div class="mt-12 p-8 bg-gray-50 rounded-3xl border border-gray-100">
              <h4 class="font-black text-secondary mb-4 italic">Tại sao nên chọn iDecal?</h4>
              <ul class="space-y-3">
                <li class="flex items-center gap-2 text-gray-600 text-sm"><span class="text-primary font-bold">✓</span> Có mặt khảo sát sau 30-60 phút tại nội thành.</li>
                <li class="flex items-center gap-2 text-gray-600 text-sm"><span class="text-primary font-bold">✓</span> Miễn phí hoàn toàn phí thiết kế Logo lên decal.</li>
                <li class="flex items-center gap-2 text-gray-600 text-sm"><span class="text-primary font-bold">✓</span> Thợ thi công lành nghề, nhiệt tình, sạch sẽ.</li>
              </ul>
            </div>
          </div>

          <div class="bg-white p-8 md:p-12 rounded-[40px] shadow-2xl border border-gray-100 relative">
            <div class="absolute -top-6 right-10 bg-primary text-secondary px-6 py-2 rounded-full font-black text-sm">
              NHẬN TƯ VẤN NHANH
            </div>
            <h3 class="text-2xl font-black text-secondary mb-8">Gửi yêu cầu khảo sát</h3>
            
            <form action="#" class="space-y-6">
              <div>
                <label class="block text-sm font-bold text-secondary mb-2">Họ và tên của bạn *</label>
                <input type="text" placeholder="Nguyễn Văn A" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all" />
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-bold text-secondary mb-2">Số điện thoại *</label>
                  <input type="tel" placeholder="090..." class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all" />
                </div>
                <div>
                  <label class="block text-sm font-bold text-secondary mb-2">Dịch vụ quan tâm</label>
                  <select class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all">
                    <option>Decal mờ văn phòng</option>
                    <option>Phim cách nhiệt</option>
                    <option>Decal mờ 3D</option>
                    <option>Phim nội thất (Vinyl)</option>
                    <option>Dịch vụ khác</option>
                  </select>
                </div>
              </div>

              <div>
                <label class="block text-sm font-bold text-secondary mb-2">Lời nhắn / Địa chỉ khảo sát</label>
                <textarea rows="4" placeholder="Ví dụ: Tôi cần dán decal mờ cho 5 phòng họp tại Quận 1..." class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all"></textarea>
              </div>

              <button type="submit" class="w-full bg-secondary text-white font-black py-5 rounded-2xl hover:bg-gray-800 transition-all shadow-xl text-lg uppercase tracking-wider">
                Gửi yêu cầu ngay
              </button>
              <p class="text-center text-xs text-gray-400">Chúng tôi cam kết bảo mật thông tin khách hàng 100%.</p>
            </form>
          </div>

        </div>
      </div>
    </section>
  </main>
</Layout>
