---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="iDecal - Thi công decal & film nội thất">

<main class="w-full">

  <!-- 🌿 HERO -->
  <section class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
        Thi công decal & film nội thất<br/>
        <span class="text-gray-600">Làm mới không gian không cần đập phá</span>
      </h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8">
        Biến tủ bếp cũ, cửa gỗ trầy xước hay văn phòng xuống cấp trở nên như mới —
        nhanh, sạch, tiết kiệm đến 70% chi phí.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#contact" class="bg-black text-white px-8 py-4 rounded-2xl font-medium hover:opacity-90 transition">
          Nhận báo giá nhanh
        </a>
        <a href="tel:0900000000" class="border px-8 py-4 rounded-2xl font-medium hover:bg-gray-100 transition">
          📞 Gọi tư vấn
        </a>
      </div>
    </div>
  </section>

  <!-- 🧱 PROBLEM -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">
        Bạn đang gặp những vấn đề này?
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        <div class="p-6 border rounded-2xl">Tủ bếp cũ bong tróc</div>
        <div class="p-6 border rounded-2xl">Cửa gỗ xuống màu</div>
        <div class="p-6 border rounded-2xl">Văn phòng cũ kỹ</div>
        <div class="p-6 border rounded-2xl">Ngại đập phá, chi phí cao</div>
      </div>

      <p class="text-center mt-10 text-gray-600">
        Film nội thất là cách cải tạo nhanh – gọn – tiết kiệm nhất.
      </p>
    </div>
  </section>

  <!-- 🎯 SERVICES -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">
        Dịch vụ của iDecal
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          "Dán tủ bếp",
          "Dán cửa gỗ",
          "Dán nội thất văn phòng",
          "Dán thang máy",
          "Dán showroom / spa",
          "Dán trang trí nội thất"
        ].map(item => (
          <div class="p-6 bg-white border rounded-2xl hover:shadow transition">
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ✨ BENEFITS -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">
        Vì sao khách hàng chọn giải pháp này?
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          "Tiết kiệm 50–70% chi phí",
          "Thi công nhanh 1–2 ngày",
          "Không bụi bẩn, không đập phá",
          "Đa dạng mẫu mã",
          "Dễ thay đổi",
          "Tăng thẩm mỹ ngay lập tức"
        ].map(item => (
          <div class="p-6 border rounded-2xl">
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 🛠 PROCESS -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">
        Quy trình thi công
      </h2>

      <div class="grid md:grid-cols-5 gap-6 text-center">
        {[
          "Khảo sát",
          "Chọn mẫu",
          "Báo giá",
          "Thi công",
          "Bàn giao"
        ].map(step => (
          <div class="p-4">
            <div class="text-xl font-semibold mb-2">{step}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 🧪 BEFORE AFTER -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">
        Trước & sau khi thi công
      </h2>
      <p class="text-gray-600">
        (Thêm hình before/after tại đây)
      </p>
    </div>
  </section>

  <!-- 🏢 APPLICATION -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">
        Ứng dụng thực tế
      </h2>

      <div class="grid md:grid-cols-3 gap-6 text-center">
        {[
          "Căn hộ / nhà phố",
          "Văn phòng",
          "Khách sạn",
          "Spa / showroom",
          "Nhà hàng",
          "Quán café"
        ].map(item => (
          <div class="p-6 border rounded-2xl bg-white">
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 💬 TRUST -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-10">
        Vì sao chọn iDecal?
      </h2>

      <div class="space-y-4 text-gray-700">
        <p>✔️ Kinh nghiệm thi công thực tế</p>
        <p>✔️ Đội ngũ tay nghề cao</p>
        <p>✔️ Vật liệu chất lượng</p>
        <p>✔️ Thi công đúng tiến độ</p>
        <p>✔️ Bảo hành rõ ràng</p>
      </div>
    </div>
  </section>

  <!-- ❓ FAQ -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-10">
        Câu hỏi thường gặp
      </h2>

      <div class="space-y-6">
        <div>
          <h3 class="font-semibold">Film có bền không?</h3>
          <p class="text-gray-600">Tuổi thọ trung bình 5–10 năm.</p>
        </div>
        <div>
          <h3 class="font-semibold">Thi công mất bao lâu?</h3>
          <p class="text-gray-600">Thông thường 1–2 ngày.</p>
        </div>
        <div>
          <h3 class="font-semibold">Có ảnh hưởng sinh hoạt không?</h3>
          <p class="text-gray-600">Không — thi công sạch, gọn.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 📞 CTA -->
  <section id="contact" class="py-20 bg-black text-white text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-6">
        Làm mới không gian của bạn ngay hôm nay
      </h2>
      <p class="mb-8 text-gray-300">
        Chỉ một lớp film — không gian thay đổi hoàn toàn.
      </p>

      <a href="tel:0900000000" class="bg-white text-black px-8 py-4 rounded-2xl font-medium">
        📞 Gọi ngay
      </a>
    </div>
  </section>

</main>

</BaseLayout>
