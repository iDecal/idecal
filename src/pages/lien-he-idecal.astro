---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Liên hệ iDecal.vn | Tư vấn thi công Decal & Phim cách nhiệt";
const description = "Liên hệ iDecal tại Thủ Đức, TP.HCM để nhận báo giá thi công decal dán kính, phim cách nhiệt nhà kính chuyên nghiệp. Hotline: 0866-77040.";
---

<Layout title={title} description={description}>
  <Header />

  <main class="bg-base-50 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h1 class="text-4xl md:text-5xl font-black text-primary-900 mb-4">Liên Hệ Với Chúng Tôi</h1>
        <p class="text-lg text-base-600">
          Đội ngũ chuyên viên của iDecal luôn sẵn sàng khảo sát tận nơi và tư vấn giải pháp tối ưu nhất cho không gian của bạn.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-start">
        
        <div class="space-y-8">
          <div class="bg-white p-8 rounded-3xl shadow-sm border border-base-200">
            <h2 class="text-2xl font-bold text-primary-800 mb-8">Thông tin chính thức</h2>
            
            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <p class="font-bold text-base-900">Địa chỉ văn phòng</p>
                  <p class="text-base-600">606/20 Quốc lộ 13, P. Hiệp Bình Phước, TP. Thủ Đức, TP.HCM</p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="w-12 h-12 bg-accent-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="font-bold text-base-900">Hotline tư vấn (24/7)</p>
                  <a href="tel:086677040" class="text-primary-600 text-xl font-black">0866-77040</a>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="font-bold text-base-900">Email báo giá</p>
                  <p class="text-base-600">hi@idecal.vn</p>
                </div>
              </div>
            </div>
          </div>

          <div class="rounded-3xl overflow-hidden shadow-sm border border-base-200 h-64 grayscale hover:grayscale-0 transition-all">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3918.490807661266!2d106.7090!3d10.8504!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDUxJzAxLjQiTiAxMDbCsDQyJzMyLjQiRQ!5e0!3m2!1svi!2svn!4v1713430000000!5m2!1svi!2svn" 
              width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

        <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl border border-base-100">
          <h2 class="text-2xl font-bold text-primary-900 mb-2">Gửi yêu cầu báo giá</h2>
          <p class="text-base-500 mb-8 italic">Vui lòng để lại thông tin, chúng tôi sẽ gọi lại ngay trong 15 phút.</p>
          
          <form class="space-y-5">
            <div class="grid md:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-bold text-base-700 mb-2">Họ tên của bạn *</label>
                <input type="text" placeholder="Nguyễn Văn A" class="w-full px-4 py-3 rounded-xl border border-base-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all" required/>
              </div>
              <div>
                <label class="block text-sm font-bold text-base-700 mb-2">Số điện thoại *</label>
                <input type="tel" placeholder="090x.xxx.xxx" class="w-full px-4 py-3 rounded-xl border border-base-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all" required/>
              </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-base-700 mb-2">Loại dịch vụ quan tâm</label>
              <select class="w-full px-4 py-3 rounded-xl border border-base-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all">
                <option>Decal mờ văn phòng</option>
                <option>Phim cách nhiệt nhà kính</option>
                <option>Film dán nội thất</option>
                <option>Decal quảng cáo/Xe</option>
                <option>Khác</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-bold text-base-700 mb-2">Lời nhắn / Địa chỉ khảo sát</label>
              <textarea rows="4" placeholder="Ví dụ: Tôi muốn dán 20m2 decal mờ tại Quận 7..." class="w-full px-4 py-3 rounded-xl border border-base-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all"></textarea>
            </div>

            <button type="submit" class="w-full bg-primary-600 hover:bg-primary-700 text-white font-black py-4 rounded-xl shadow-lg hover:shadow-primary-200 transition-all active:scale-95 uppercase">
              Gửi yêu cầu ngay
            </button>
          </form>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>
