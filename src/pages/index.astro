        <div class="text-base-500 text-sm uppercase tracking-wider">Tận xưởng</div>
      </div>
    </div>
  </section>

  <section id="products" class="py-20 max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="text-3xl font-bold text-base-900">Sản phẩm nổi bật</h2>
        <p class="text-base-500 mt-2">Đa dạng chất liệu, đáp ứng mọi nhu cầu kinh doanh</p>
      </div>
      <a href="/shop" class="text-primary-600 font-semibold hover:underline">Xem tất cả &rarr;</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-base-100">
        <div class="h-64 bg-base-200 overflow-hidden">
          <img src="/images/decal-tem-nhan.jpg" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2">Decal Tem Nhãn</h3>
          <p class="text-base-600 text-sm mb-4">Chống nước, bám dính cực tốt trên mọi bề mặt sản phẩm.</p>
          <button class="w-full py-2 bg-base-100 text-base-800 font-semibold rounded hover:bg-primary-500 hover:text-white transition-colors">Tìm hiểu thêm</button>
        </div>
      </div>

      <div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-base-100">
        <div class="h-64 bg-base-200 overflow-hidden">
          <img src="/images/decal-xe.jpg" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2">Decal Dán Xe</h3>
          <p class="text-base-600 text-sm mb-4">Chất liệu PVC cao cấp, không bay màu, bảo vệ sơn xe tối ưu.</p>
          <button class="w-full py-2 bg-base-100 text-base-800 font-semibold rounded hover:bg-primary-500 hover:text-white transition-colors">Tìm hiểu thêm</button>
        </div>
      </div>

      <div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow border border-base-100">
        <div class="h-64 bg-base-200 overflow-hidden">
          <img src="/images/decal-quang-cao.jpg" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2">Decal Quảng Cáo</h3>
          <p class="text-base-600 text-sm mb-4">Giải pháp in khổ lớn cho cửa hàng, sự kiện và văn phòng.</p>
          <button class="w-full py-2 bg-base-100 text-base-800 font-semibold rounded hover:bg-primary-500 hover:text-white transition-colors">Tìm hiểu thêm</button>
        </div>
      </div>
    </div>
  </section>

  <section class="my-20 max-w-5xl mx-auto px-6">
    <div class="bg-accent-500 rounded-3xl p-10 md:p-16 flex flex-col items-center text-center text-white shadow-2xl">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Sẵn sàng đưa thương hiệu của bạn vươn xa?</h2>
      <p class="text-accent-50 mb-8 max-w-2xl text-lg">
        Liên hệ ngay để nhận tư vấn miễn phí và bản thiết kế demo cho sản phẩm của bạn.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <button class="bg-white text-accent-600 px-10 py-4 rounded-full font-bold text-lg shadow-md hover:scale-105 transition-transform">
          Zalo: 09xx.xxx.xxx
        </button>
        <button class="bg-primary-700 text-white px-10 py-4 rounded-full font-bold text-lg shadow-md hover:bg-primary-800 transition-colors">
          Gửi Yêu Cầu
        </button>
      </div>
    </div>
  </section>

</main>
