---
import Layout from '../layouts/Layout.astro';

const title = "iDecal.vn | Decal dán kính cách nhiệt & Decal mờ trang trí chuyên nghiệp";
const description = "Chuyên gia cung cấp giải pháp decal dán kính, phim cách nhiệt nhà kính, văn phòng tại TP. Thủ Đức, TP.HCM & Bình Dương. Đối tác của 200+ công ty nội thất.";
---

<Layout title={title} description={description}>
  <main class="bg-white">
    <section class="relative bg-secondary text-white py-16 lg:py-24 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center relative z-10">
        <div>
          <span class="inline-block bg-primary text-secondary px-4 py-1.5 rounded-full text-sm font-black mb-6 uppercase tracking-wider">
            Đối tác của 200+ công ty nội thất
          </span>
          <h1 class="text-4xl md:text-5xl font-heading font-black leading-tight mb-6">
            iDecal – Decal dán kính <span class="text-primary">cách nhiệt</span> & Decal mờ trang trí
          </h1>
          <p class="text-lg text-gray-300 mb-8 leading-relaxed max-w-xl">
            Chuyên gia hàng đầu cung cấp giải pháp decal dán kính chất lượng cao, tối ưu không gian sống và làm việc với cam kết chất lượng tuyệt đối.
          </p>
          <div class="flex flex-wrap gap-4 mb-10">
            <a href="tel:0866077040" class="bg-primary hover:bg-yellow-400 text-secondary px-8 py-4 rounded-xl font-black text-lg shadow-lg transition-all active:scale-95">
              NHẬN BÁO GIÁ MIỄN PHÍ
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 bg-primary/10 blur-3xl rounded-full"></div>
          <img src="/Dich-vu-decal-dan-kinh-cach-nhiet.webp" alt="Thi công decal dán kính chuyên nghiệp iDecal" class="rounded-3xl shadow-2xl relative z-10 border-8 border-gray-800/50" />
        </div>
      </div>
    </section>

    <section class="py-12 bg-gray-50 border-y border-gray-100">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-center text-gray-500 text-sm font-bold uppercase tracking-widest mb-8">Sử dụng vật liệu từ các thương hiệu hàng đầu</p>
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-60">
          <img src="/images/logos/3m.svg" alt="3M" class="h-8 md:h-12 grayscale hover:grayscale-0 transition-all" />
          <img src="/images/logos/avery.svg" alt="Avery Dennison" class="h-8 md:h-12 grayscale hover:grayscale-0 transition-all" />
          <img src="/images/logos/llumar.svg" alt="Llumar" class="h-8 md:h-12 grayscale hover:grayscale-0 transition-all" />
          <img src="/images/logos/oracal.svg" alt="Oracal" class="h-8 md:h-12 grayscale hover:grayscale-0 transition-all" />
          <img src="/images/logos/nk.svg" alt="NK" class="h-8 md:h-12 grayscale hover:grayscale-0 transition-all" />
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-secondary font-bold uppercase tracking-widest text-sm mb-3">Dịch vụ thế mạnh</h2>
          <h3 class="text-3xl md:text-5xl font-heading font-black text-secondary mb-4">Giải pháp Decal trọn gói</h3>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/decal-mo-3d.webp" alt="Thi công decal mờ 3D iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Decal mờ 3D</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Thiết kế vân nổi sống động, tạo chiều sâu sang trọng. Độ mờ 20-30% tạo sự riêng tư tinh tế.</p>
              <a href="/decal-mo-3d" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/phim-cach-nhiet.webp" alt="Phim cách nhiệt 3M Llumar iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Phim cách nhiệt</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">3M, Llumar chính hãng: Cách nhiệt 80%, chống 99% tia UV bảo vệ sức khỏe.</p>
              <a href="/phim-cach-nhiet" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/decal-cat-chu.webp" alt="Cắt chữ decal logo công ty iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Decal cắt chữ</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Cắt decal máy sắc nét: Logo, sticker nhận diện thương hiệu công ty.</p>
              <a href="/decal-cat-chu" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/phim-dan-noi-that.webp" alt="Film dán nội thất vân gỗ đá iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Phim dán nội thất</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Làm mới tủ bếp, bàn ghế với film Vinyl vân gỗ, đá vân sang trọng.</p>
              <a href="/film-noithat" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/decal-quang-cao.webp" alt="In ấn decal quảng cáo khổ lớn iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Decal quảng cáo</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">In PP, decal xe, bảng hiệu quảng cáo chất lượng cao, bền màu nắng mưa.</p>
              <a href="/decal-quang-cao" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/decal-van-phong.webp" alt="Decal mờ dán kính văn phòng iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Decal văn phòng</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Giải pháp vách kính mờ chuyên nghiệp cho văn phòng hiện đại.</p>
              <a href="/decal-van-phong" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết <span>→</span></a>
            </div>
          </div>

        </div>
      </div>
    </section>

    </main>
</Layout>
