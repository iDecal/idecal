---
import Layout from '../layouts/Layout.astro';

const title = "iDecal.vn | Decal dán kính cách nhiệt & Decal mờ trang trí chuyên nghiệp";
const description = "Chuyên gia cung cấp giải pháp decal dán kính, phim cách nhiệt nhà kính, văn phòng tại TP. Thủ Đức, TP.HCM & Bình Dương. Đối tác của 200+ công ty nội thất.";
---

<Layout title={title} description={description}>
  <main class="bg-white">
    <section class="relative bg-secondary text-white py-16 lg:py-24 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center relative z-10">
        <div>
          <span class="inline-block bg-primary text-secondary px-4 py-1.5 rounded-full text-sm font-black mb-6 uppercase tracking-wider">
            Đối tác của 200+ công ty nội thất
          </span>
          <h1 class="text-4xl md:text-5xl font-heading font-black leading-tight mb-6">
            iDecal – Decal dán kính <span class="text-primary">cách nhiệt</span> & Decal mờ trang trí
          </h1>
          <p class="text-lg text-gray-300 mb-8 leading-relaxed max-w-xl">
            Chào mừng bạn đến với <strong>iDecal</strong> – Chuyên gia hàng đầu cung cấp các giải pháp decal dán kính chất lượng cao. Chúng tôi tối ưu hóa không gian sống và làm việc của bạn.
          </p>
          <div class="flex flex-wrap gap-4 mb-10">
            <a href="tel:0866077040" class="bg-primary hover:scale-105 text-secondary px-8 py-4 rounded-xl font-black text-lg shadow-lg transition-all active:scale-95">
              NHẬN BÁO GIÁ MIỄN PHÍ
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm font-bold text-gray-400">
            <div class="flex items-center gap-2"><span class="text-primary text-xl">✓</span> Thi công chuyên nghiệp</div>
            <div class="flex items-center gap-2"><span class="text-primary text-xl">✓</span> Bảo hành 2-5 năm</div>
            <div class="flex items-center gap-2"><span class="text-primary text-xl">✓</span> Giá cạnh tranh tận xưởng</div>
          </div>
        </div>
        
        <div class="relative">
          <div class="absolute -inset-4 bg-primary/10 blur-3xl rounded-full"></div>
          <img src="/Dich-vu-decal-dan-kinh-cach-nhiet.webp" alt="Thi công decal dán kính chuyên nghiệp iDecal" class="rounded-3xl shadow-2xl relative z-10 border-8 border-gray-800" />
          <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-2xl z-20 hidden md:block">
            <p class="text-4xl font-black text-secondary">96.5%</p>
            <p class="text-gray-500 text-xs uppercase font-bold tracking-tighter">Khách hàng hài lòng</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gray-50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-secondary font-bold uppercase tracking-widest text-sm mb-3">Dịch vụ thế mạnh</h2>
          <h3 class="text-3xl md:text-5xl font-heading font-black text-secondary mb-4">Giải pháp Decal dán kính trọn gói</h3>
          <p class="text-gray-600 text-lg">Chúng tôi cung cấp giải pháp trang trí kính & Dịch vụ decal dán kính cách nhiệt toàn diện</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/decal-mo-3d.webp" alt="Thi công decal mờ 3D iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Decal mờ 3D</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Thiết kế vân nổi sống động. Độ trong suốt 20-30% tạo sự riêng tư tinh tế.</p>
              <a href="/decal-mo-3d" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết sản phẩm <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/phim-cach-nhiet.webp" alt="Phim cách nhiệt 3M Llumar iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Phim cách nhiệt</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">3M, Llumar: Cách nhiệt 80%, chống 99% UV. Bảo vệ kính và sức khỏe tối ưu.</p>
              <a href="/phim-cach-nhiet" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết thêm <span>→</span></a>
            </div>
          </div>

          </div>
      </div>
    </section>

    <section class="py-12 bg-accent">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <h3 class="text-2xl md:text-3xl font-heading font-black text-secondary mb-4 italic underline decoration-primary underline-offset-8">
          Tư vấn từ chuyên gia iDecal
        </h3>
        <p class="text-secondary mb-10 max-w-2xl mx-auto text-lg">
          Khảo sát tận nơi hoàn toàn miễn phí tại TP.HCM & các tỉnh lân cận.
        </p>
        <div class="bg-white/50 p-8 rounded-3xl border border-dashed border-secondary mb-10 inline-block w-full max-w-md">
           <p class="text-xs text-secondary font-bold uppercase tracking-widest mb-2">Đường dây nóng 24/7</p>
           <a href="tel:086677040" class="text-4xl md:text-5xl font-black text-secondary hover:text-primary transition-colors tracking-tight">
             0866-77040
           </a>
        </div>
        <a href="/lien-he" class="block w-full max-w-md mx-auto bg-secondary text-white font-black py-5 rounded-2xl hover:bg-opacity-90 transition-all shadow-xl text-xl uppercase tracking-wider">
          ĐẶT THIẾT KẾ MẪU NGAY
        </a>
      </div>
    </section>

  </main>
</Layout>
