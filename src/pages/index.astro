---
import Layout from '../layouts/Layout.astro';
// Thêm các dòng import dưới đây:
import hero from '../components/hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProcessStep from '../components/ProcessStep.astro';

const title = "iDecal.vn | Decal dán kính cách nhiệt & Decal mờ trang trí chuyên nghiệp";
const description = "Chuyên gia cung cấp giải pháp decal dán kính, phim cách nhiệt nhà kính, văn phòng...";
---

<Layout title={title} description={description}>
  <main class="bg-surface-100">
    <hero 
      badge="Đối tác của 200+ công ty nội thất"
      ...
    />
    
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-8">
        <ServiceCard ... />
      </div>
    </section>

    </main>
</Layout>
