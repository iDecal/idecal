---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// SEO Meta
const title = "iDecal.vn | Decal dán kính cách nhiệt & Decal mờ trang trí chuyên nghiệp";
const description = "Chuyên gia cung cấp giải pháp decal dán kính, phim cách nhiệt nhà ở, văn phòng tại TP.HCM & Bình Dương. Đối tác của 200+ công ty nội thất.";
---

<Layout title={title} description={description}>
  <Header />

  <main class="font-sans">
    <section class="relative bg-primary-900 text-white py-20 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center relative z-10">
        <div>
          <span class="inline-block bg-accent-500 text-primary-900 px-4 py-1 rounded-full text-sm font-bold mb-4">
            Đối tác của 200+ công ty nội thất
          </span>
          <h1 class="text-4xl md:text-5xl font-black leading-tight mb-6">
            iDecal – Decal dán kính cách nhiệt & <span class="text-accent-500">Decal mờ</span> trang trí
          </h1>
          <p class="text-lg text-primary-100 mb-8 leading-relaxed">
            Chào mừng bạn đến với <strong>iDecal</strong> – Chuyên gia hàng đầu cung cấp giải pháp decal dán kính chất lượng cao. Từ văn phòng đến nhà ở, chúng tôi cam kết sự hài lòng tuyệt đối.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="tel:086677040" class="bg-accent-500 hover:bg-accent-400 text-primary-900 px-8 py-4 rounded-xl font-black text-lg shadow-lg transition-all active:scale-95">
              NHẬN BÁO GIÁ MIỄN PHÍ
            </a>
          </div>
          <div class="mt-8 grid grid-cols-3 gap-4 text-sm font-semibold text-primary-200">
            <div class="flex items-center gap-2">✓ Thi công chuyên nghiệp</div>
            <div class="flex items-center gap-2">✓ Bảo hành 2-5 năm</div>
            <div class="flex items-center gap-2">✓ Giá cạnh tranh</div>
          </div>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 bg-accent-500/20 blur-3xl rounded-full"></div>
          <img src="/Dich-vu-decal-dan-kinh-cach-nhiet.webp" alt="Thi công decal dán kính" class="rounded-2xl shadow-2xl relative z-10 border-4 border-primary-800" />
          <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl z-20 hidden lg:block">
            <p class="text-4xl font-black text-primary-600">96.5%</p>
            <p class="text-base-600 text-xs uppercase font-bold tracking-tighter">Khách hàng hài lòng</p>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="py-24 bg-base-50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl md:text-4xl font-black text-primary-900 mb-4">Dịch vụ Decal dán kính trọn gói</h2>
          <p class="text-base-600">Chúng tôi cung cấp giải pháp trang trí kính & dịch vụ decal dán kính cách nhiệt toàn diện.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-base-200 hover:border-primary-500 transition-all group">
            <div class="w-14 h-14 bg-primary-50 rounded-lg flex items-center justify-center mb-6 group-hover:bg-primary-500 transition-colors">
              <svg class="w-8 h-8 text-primary-600 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-base-900">Decal mờ 3D</h3>
            <p class="text-base-600 text-sm mb-4">Thiết kế vân nổi sống động. Tạo chiều sâu, nét độc đáo sang trọng cho kính.</p>
            <a href="#" class="text-primary-600 font-bold text-sm hover:underline">Chi tiết thêm →</a>
          </div>

          <div class="bg-white p-8 rounded-2xl shadow-sm border border-base-200 hover:border-primary-500 transition-all group">
            <div class="w-14 h-14 bg-primary-50 rounded-lg flex items-center justify-center mb-6 group-hover:bg-primary-500 transition-colors">
              <svg class="w-8 h-8 text-primary-600 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707-.707"></path></svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-base-900">Phim cách nhiệt</h3>
            <p class="text-base-600 text-sm mb-4">3M, Llumar: Cách nhiệt 80%, chống 99% UV. Giảm chói và bảo vệ kính tối ưu.</p>
            <a href="#" class="text-primary-600 font-bold text-sm hover:underline">Chi tiết thêm →</a>
          </div>

          </div>
      </div>
    </section>

    <section class="py-20 bg-accent-500">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-5xl font-black text-primary-900 mb-6">Bạn cần tư vấn từ chuyên gia?</h2>
        <p class="text-primary-800 text-xl mb-10 font-medium">Chúng tôi trả lời mọi thắc mắc 24/7 qua Hotline</p>
        <a href="tel:086677040" class="inline-flex items-center gap-4 bg-primary-900 text-white px-10 py-5 rounded-full text-2xl font-black hover:scale-105 transition-transform">
           Gọi ngay: 0866-77040
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
