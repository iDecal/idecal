---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "iDecal.vn | Decal dán kính cách nhiệt & Decal mờ trang trí chuyên nghiệp";
const description = "Chuyên gia cung cấp giải pháp decal dán kính, phim cách nhiệt nhà kính, văn phòng tại TP. Thủ Đức, TP.HCM & Bình Dương. Đối tác của 200+ công ty nội thất.";
---

<Layout title={title} description={description}>
  <Header />

  <main class="font-sans bg-white">
    <section class="relative bg-primary-900 text-white py-16 lg:py-24 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center relative z-10">
        <div>
          <span class="inline-block bg-accent-500 text-primary-900 px-4 py-1.5 rounded-full text-sm font-black mb-6 uppercase tracking-wider">
            Đối tác của 200+ công ty nội thất
          </span>
          <h1 class="text-4xl md:text-6xl font-black leading-tight mb-6">
            iDecal – Decal dán kính <span class="text-accent-500">cách nhiệt</span> & Decal mờ trang trí
          </h1>
          <p class="text-lg text-primary-100 mb-8 leading-relaxed max-w-xl">
            Chào mừng bạn đến với <strong>iDecal</strong> – Chuyên gia hàng đầu cung cấp các giải pháp decal dán kính chất lượng cao. Chúng tôi tối ưu hóa không gian sống và làm việc của bạn với cam kết chất lượng tuyệt đối.
          </p>
          <div class="flex flex-wrap gap-4 mb-10">
            <a href="tel:086677040" class="bg-accent-500 hover:bg-accent-400 text-primary-900 px-8 py-4 rounded-xl font-black text-lg shadow-lg transition-all active:scale-95">
              NHẬN BÁO GIÁ MIỄN PHÍ
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm font-bold text-primary-200">
            <div class="flex items-center gap-2"><span class="text-accent-500 text-xl">✓</span> Thi công chuyên nghiệp</div>
            <div class="flex items-center gap-2"><span class="text-accent-500 text-xl">✓</span> Bảo hành 2-5 năm</div>
            <div class="flex items-center gap-2"><span class="text-accent-500 text-xl">✓</span> Giá cạnh tranh tận xưởng</div>
          </div>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 bg-accent-500/10 blur-3xl rounded-full"></div>
          <img src="/images/hero-idecal.webp" alt="Thi công decal dán kính chuyên nghiệp iDecal" class="rounded-3xl shadow-2xl relative z-10 border-8 border-primary-800/50" />
          <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-2xl z-20 hidden md:block">
            <p class="text-4xl font-black text-primary-600">96.5%</p>
            <p class="text-base-600 text-xs uppercase font-bold tracking-tighter">Khách hàng hài lòng</p>
          </div>
        </div>
      </div>
    </section>

   <section class="py-24 bg-base-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-primary-600 font-bold uppercase tracking-widest text-sm mb-3">Dịch vụ thế mạnh</h2>
      <h3 class="text-3xl md:text-5xl font-black text-primary-900 mb-4">Giải pháp Decal dán kính trọn gói</h3>
      <p class="text-base-600 text-lg">Chúng tôi cung cấp giải pháp trang trí kính & Dịch vụ decal dán kính cách nhiệt toàn diện</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-base-200 group overflow-hidden">
        <div class="aspect-video overflow-hidden">
          <img src="/images/decal-mo-3d.webp" alt="Thi công decal mờ 3D iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
        </div>
        <div class="p-8">
          <h3 class="text-xl font-black mb-3 text-primary-800">Decal mờ 3D</h3>
          <p class="text-base-600 text-sm mb-6 leading-relaxed">Thiết kế vân nổi sống động. Tạo chiều sâu, nét độc đáo sang trọng cho kính. Độ trong suốt 20-30% tạo sự riêng tư tinh tế.</p>
          <a href="/decal-mo-3d" class="text-primary-600 font-bold text-sm flex items-center gap-2 group-hover:text-accent-600 transition-colors">Chi tiết sản phẩm <span>→</span></a>
        </div>
      </div>

      <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-base-200 group overflow-hidden">
        <div class="aspect-video overflow-hidden">
          <img src="/images/phim-cach-nhiet.webp" alt="Phim cách nhiệt 3M Llumar iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
        </div>
        <div class="p-8">
          <h3 class="text-xl font-black mb-3 text-primary-800">Phim cách nhiệt</h3>
          <p class="text-base-600 text-sm mb-6 leading-relaxed">3M, Llumar: Cách nhiệt 80%, chống 99% UV. Giải pháp làm giảm ánh sáng, chống chói, bảo vệ kính và sức khỏe tối ưu.</p>
          <a href="/phim-cach-nhiet" class="text-primary-600 font-bold text-sm flex items-center gap-2 group-hover:text-accent-600 transition-colors">Chi tiết thêm <span>→</span></a>
        </div>
      </div>

      <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-base-200 group overflow-hidden">
        <div class="aspect-video overflow-hidden">
          <img src="/images/decal-cat-chu.webp" alt="Cắt chữ decal logo công ty iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
        </div>
        <div class="p-8">
          <h3 class="text-xl font-black mb-3 text-primary-800">Decal cắt chữ</h3>
          <p class="text-base-600 text-sm mb-6 leading-relaxed">Sticker, nhãn dán, Cắt decal theo yêu cầu – Sắc nét, bền màu, bám dính tốt trên mọi bề mặt phẳng.</p>
          <a href="/decal-cat-chu" class="text-primary-600 font-bold text-sm flex items-center gap-2 group-hover:text-accent-600 transition-colors">Chi tiết thêm <span>→</span></a>
        </div>
      </div>

      <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-base-200 group overflow-hidden">
        <div class="aspect-video overflow-hidden">
          <img src="/images/phim-dan-noi-that.webp" alt="Film dán nội thất vân gỗ đá iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
        </div>
        <div class="p-8">
          <h3 class="text-xl font-black mb-3 text-primary-800">Phim dán nội thất</h3>
          <p class="text-base-600 text-sm mb-6 leading-relaxed">Tái tạo không gian. Mẫu film đa dạng từ vân gỗ, đá, kim loại. Làm mới đồ nội thất nhanh chóng và tiết kiệm chi phí.</p>
          <a href="/film-noithat" class="text-primary-600 font-bold text-sm flex items-center gap-2 group-hover:text-accent-600 transition-colors">Chi tiết thêm <span>→</span></a>
        </div>
      </div>

      <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-base-200 group overflow-hidden">
        <div class="aspect-video overflow-hidden">
          <img src="/images/decal-quang-cao.webp" alt="In ấn decal quảng cáo khổ lớn iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
        </div>
        <div class="p-8">
          <h3 class="text-xl font-black mb-3 text-primary-800">Decal quảng cáo</h3>
          <p class="text-base-600 text-sm mb-6 leading-relaxed">Giải pháp in ấn Decal khổ lớn. Phù hợp dán tường, dán kính, dán xe. Chất liệu PP, Vinyl bền màu, thu hút khách hàng.</p>
          <a href="/decal-quang-cao" class="text-primary-600 font-bold text-sm flex items-center gap-2 group-hover:text-accent-600 transition-colors">Chi tiết thêm <span>→</span></a>
        </div>
      </div>

      <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-base-200 group overflow-hidden">
        <div class="aspect-video overflow-hidden">
          <img src="/images/decal-van-phong.webp" alt="Decal mờ dán kính văn phòng iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
        </div>
        <div class="p-8">
          <h3 class="text-xl font-black mb-3 text-primary-800">Decal văn phòng</h3>
          <p class="text-base-600 text-sm mb-6 leading-relaxed">Tạo sự riêng tư, chuyên nghiệp cho văn phòng. Che mờ kính, chống lóa và nổi bật Logo nhận diện công ty.</p>
          <a href="/decal-van-phong" class="text-primary-600 font-bold text-sm flex items-center gap-2 group-hover:text-accent-600 transition-colors">Chi tiết thêm <span>→</span></a>
        </div>
      </div>

    </div>
  </div>
</section>
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-3 gap-0 rounded-3xl overflow-hidden shadow-2xl border border-base-200">
      
      <div class="p-10 bg-primary-900 text-white relative group">
        <div class="text-accent-500 font-black text-6xl opacity-20 absolute top-4 right-6">01</div>
        <h3 class="text-2xl font-black mb-4">THIẾT KẾ ĐỘC QUYỀN</h3>
        <p class="text-primary-100 text-sm leading-relaxed mb-6">
          Đội ngũ designer của iDecal hỗ trợ tùy chỉnh mẫu, chèn logo, căn chỉnh kích thước chuẩn xác theo từng vách kính. Đảm bảo tính thẩm mỹ và nhận diện thương hiệu.
        </p>
        <img src="/images/design-process.webp" alt="Thiết kế decal" class="rounded-xl opacity-80 group-hover:opacity-100 transition-all h-40 w-full object-cover" />
      </div>

      <div class="p-10 bg-primary-800 text-white relative group border-x border-primary-700">
        <div class="text-accent-500 font-black text-6xl opacity-20 absolute top-4 right-6">02</div>
        <h3 class="text-2xl font-black mb-4">IN ẤN SẮC NÉT</h3>
        <p class="text-primary-100 text-sm leading-relaxed mb-6">
          Sở hữu hệ thống máy in kỹ thuật số hiện đại, mực Eco-Solvent bền màu. Đảm bảo hình ảnh sắc nét, trung thực ngay cả trên chất liệu decal mờ hay PP.
        </p>
        <img src="/images/print-process.webp" alt="Máy in decal hiện đại" class="rounded-xl opacity-80 group-hover:opacity-100 transition-all h-40 w-full object-cover" />
      </div>

      <div class="p-10 bg-primary-700 text-white relative group">
        <div class="text-accent-500 font-black text-6xl opacity-20 absolute top-4 right-6">03</div>
        <h3 class="text-2xl font-black mb-4">THI CÔNG TẬN TÂM</h3>
        <p class="text-primary-100 text-sm leading-relaxed mb-6">
          Đội thợ lành nghề trực tiếp thi công tại công trình. Đảm bảo bề mặt phẳng mịn, không bọt khí, vệ sinh sạch sẽ sau khi hoàn thiện.
        </p>
        <img src="/images/install-process.webp" alt="Thợ dán decal chuyên nghiệp" class="rounded-xl opacity-80 group-hover:opacity-100 transition-all h-40 w-full object-cover" />
      </div>

    </div>
  </div>
</section>
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-black text-primary-900 mb-6">Tại sao chọn iDecal</h2>
          <p class="text-base-600 mb-8 leading-relaxed">iDecal mang đến giải pháp trang trí – chống nóng – tạo không gian riêng tư với mẫu mã đa dạng cho nhà ở, văn phòng, showroom và các công trình dự án lớn.</p>
          
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="bg-accent-500 p-2 rounded-lg h-fit text-primary-900">✓</div>
              <div>
                <h4 class="font-black text-primary-800">Chất lượng đảm bảo</h4>
                <p class="text-sm text-base-600">Sử dụng 100% Decal chính hãng từ 3M, Llumar, V-KOOL.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="bg-accent-500 p-2 rounded-lg h-fit text-primary-900">✓</div>
              <div>
                <h4 class="font-black text-primary-800">Thi công chuyên nghiệp</h4>
                <p class="text-sm text-base-600">Đội ngũ thợ giàu kinh nghiệm, quy trình thi công sạch sẽ, tỉ mỉ.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="bg-accent-500 p-2 rounded-lg h-fit text-primary-900">✓</div>
              <div>
                <h4 class="font-black text-primary-800">Bảo hành dài hạn</h4>
                <p class="text-sm text-base-600">Cam kết bảo hành 2-5 năm cho mọi sản phẩm thi công.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-primary-50 p-8 md:p-12 rounded-3xl">
          <h3 class="text-2xl font-black text-primary-900 mb-6 italic underline decoration-accent-500 underline-offset-8">Tư vấn từ chuyên gia</h3>
          <p class="text-base-700 mb-6">Chúng tôi thiết kế mẫu độc quyền, tích hợp logo thương hiệu và khảo sát tận nơi miễn phí.</p>
          <div class="bg-white p-6 rounded-2xl shadow-sm mb-6">
             <p class="text-sm text-base-500 mb-1 font-bold uppercase">Hotline 24/7</p>
             <a href="tel:086677040" class="text-3xl font-black text-primary-600">0866-77040</a>
          </div>
          <a href="/lien-he" class="block text-center bg-primary-600 text-white font-black py-4 rounded-xl hover:bg-primary-700 transition-colors">ĐẶT THIẾT KẾ MẪU</a>
        </div>
      </div>
    </section>
<section class="py-24 bg-base-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-primary-600 font-bold uppercase tracking-widest text-sm mb-3">Thực tế thi công</h2>
        <h3 class="text-3xl md:text-5xl font-black text-primary-900 leading-tight">Các công trình tiêu biểu bởi iDecal</h3>
      </div>
      <a href="/du-an" class="text-primary-600 font-bold hover:text-accent-600 flex items-center gap-2 mb-2 transition-colors">
        Xem tất cả dự án 
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <div class="group cursor-pointer">
        <div class="relative overflow-hidden rounded-2xl mb-4">
          <img src="/images/project-the-hive.webp" alt="Thi công decal tại The Hive Thao Dien" class="w-full h-72 object-cover group-hover:scale-110 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <p class="text-white text-sm font-medium">Thi công Backdrop & Decal kính trang trí</p>
          </div>
        </div>
        <h4 class="text-xl font-bold text-primary-900">The Hive - Thảo Điền</h4>
        <p class="text-base-500 text-sm">Quận 2, TP.HCM</p>
      </div>

      <div class="group cursor-pointer">
        <div class="relative overflow-hidden rounded-2xl mb-4">
          <img src="/images/project-toyota.webp" alt="Dán phim cách nhiệt Showroom Toyota" class="w-full h-72 object-cover group-hover:scale-110 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <p class="text-white text-sm font-medium">Phim cách nhiệt cao cấp bảo vệ Showroom</p>
          </div>
        </div>
        <h4 class="text-xl font-bold text-primary-900">Showroom Toyota</h4>
        <p class="text-base-500 text-sm">Bình Dương</p>
      </div>

      <div class="group cursor-pointer">
        <div class="relative overflow-hidden rounded-2xl mb-4">
          <img src="/images/project-office.webp" alt="Decal mờ 3D văn phòng hiện đại" class="w-full h-72 object-cover group-hover:scale-110 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <p class="text-white text-sm font-medium">Thi công Decal mờ 3D riêng tư</p>
          </div>
        </div>
        <h4 class="text-xl font-bold text-primary-900">Văn phòng Coworking Space</h4>
        <p class="text-base-500 text-sm">Quận 1, TP.HCM</p>
      </div>

    </div>
  </div>
</section>
    <section class="py-24 bg-base-100">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-black text-center text-primary-900 mb-12 uppercase">Câu hỏi thường gặp</h2>
        <div class="space-y-4 text-left">
          <details class="group bg-white rounded-2xl border border-base-200 overflow-hidden" open>
            <summary class="flex justify-between items-center p-6 cursor-pointer list-none font-bold text-primary-800">
              iDecal phục vụ những khu vực nào?
              <span class="transition group-open:rotate-180">▼</span>
            </summary>
            <p class="px-6 pb-6 text-base-600 border-t border-base-50 pt-4">Chúng tôi thi công toàn quốc, trọng tâm tại: <strong>TP.HCM, Bình Dương, Bà Rịa – Vũng Tàu, Đồng Nai, Long An...</strong></p>
          </details>
          <details class="group bg-white rounded-2xl border border-base-200 overflow-hidden">
            <summary class="flex justify-between items-center p-6 cursor-pointer list-none font-bold text-primary-800">
              Thời gian bảo hành công trình bao lâu?
              <span class="transition group-open:rotate-180">▼</span>
            </summary>
            <p class="px-6 pb-6 text-base-600 border-t border-base-50 pt-4">Bảo hành <strong>2 năm</strong> cho bong tróc. Các loại decal cao cấp bảo hành lên đến 5 năm.</p>
          </details>
          <details class="group bg-white rounded-2xl border border-base-200 overflow-hidden">
            <summary class="flex justify-between items-center p-6 cursor-pointer list-none font-bold text-primary-800">
              Tôi có thể mua Decal về tự dán được không?
              <span class="transition group-open:rotate-180">▼</span>
            </summary>
            <p class="px-6 pb-6 text-base-600 border-t border-base-50 pt-4">Được! Chúng tôi gia công sẵn và cung cấp hướng dẫn chi tiết để bạn tự thực hiện dễ dàng.</p>
          </details>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
