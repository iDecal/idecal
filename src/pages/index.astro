---
import Layout from '../layouts/Layout.astro';
---

<Layout title="idecal - Dịch vụ Decal Kính Cách Nhiệt & Trang Trí">
	<main>
		<section class="bg-secondary text-white py-20 px-4">
			<div class="max-auto max-w-4xl text-center">
				<h1 class="text-4xl md:text-6xl font-bold text-primary mb-6">
					IDECAL - GIẢI PHÁP DECAL CHUYÊN NGHIỆP
				</h1>
				<p class="text-accent text-lg mb-8">
					Dán kính cách nhiệt & Decal mờ trang trí văn phòng hiện đại.
				</p>
				<button class="bg-primary text-secondary font-bold py-3 px-8 rounded-lg hover:bg-opacity-90 transition">
					Nhận Báo Giá Ngay
				</button>
			</div>
		</section>

		<section class="py-16 px-4 max-w-6xl mx-auto">
			<h2 class="text-3xl text-center font-bold mb-12">Dịch Vụ Của Chúng Tôi</h2>
			<div class="grid md:grid-cols-2 gap-8">
				<div class="border-l-4 border-primary p-6 bg-accent bg-opacity-20 shadow-sm">
					<h3 class="text-xl font-bold mb-2">Decal Dán Kính Cách Nhiệt</h3>
					<p>Chống nóng hiệu quả, bảo vệ sức khỏe và nội thất văn phòng.</p>
				</div>
				<div class="border-l-4 border-primary p-6 bg-accent bg-opacity-20 shadow-sm">
					<h3 class="text-xl font-bold mb-2">Decal Mờ Trang Trí</h3>
					<p>Tạo không gian riêng tư, sang trọng cho kính văn phòng, cửa hàng.</p>
				</div>
			</div>
		</section>
	</main>
</Layout>
