---
import Layout from '../layouts/Layout.astro';

const title = "iDecal.vn | Decal dán kính cách nhiệt & Decal mờ trang trí chuyên nghiệp";
const description = "Chuyên gia cung cấp giải pháp decal dán kính, phim cách nhiệt nhà kính, văn phòng tại TP. Thủ Đức, TP.HCM & Bình Dương. Đối tác của 200+ công ty nội thất.";
---

<Layout title={title} description={description}>
  <main class="bg-white">
    <section class="relative bg-secondary text-white py-16 lg:py-24 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center relative z-10">
        <div>
          <span class="inline-block bg-primary text-secondary px-4 py-1.5 rounded-full text-sm font-black mb-6 uppercase tracking-wider">
            Đối tác của 200+ công ty nội thất
          </span>
          <h1 class="text-4xl md:text-5xl font-heading font-black leading-tight mb-6">
            iDecal – Decal dán kính <span class="text-primary">cách nhiệt</span> & Decal mờ trang trí
          </h1>
          <p class="text-lg text-gray-300 mb-8 leading-relaxed max-w-xl">
            Giải pháp hàng đầu cho không gian văn phòng và căn hộ. Chúng tôi cam kết chất lượng vật liệu chính hãng và kỹ thuật thi công sắc nét.
          </p>
          <div class="flex flex-wrap gap-4 mb-10">
            <a href="tel:0866077040" class="bg-primary hover:bg-yellow-400 text-secondary px-8 py-4 rounded-xl font-black text-lg shadow-lg transition-all active:scale-95">
              NHẬN BÁO GIÁ MIỄN PHÍ
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm font-bold text-gray-400">
            <div class="flex items-center gap-2"><span class="text-primary text-xl">✓</span> Thi công chuyên nghiệp</div>
            <div class="flex items-center gap-2"><span class="text-primary text-xl">✓</span> Bảo hành 2-5 năm</div>
            <div class="flex items-center gap-2"><span class="text-primary text-xl">✓</span> Giá cạnh tranh tận xưởng</div>
          </div>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 bg-primary/10 blur-3xl rounded-full"></div>
          <img src="/Dich-vu-decal-dan-kinh-cach-nhiet.webp" alt="Thi công decal dán kính chuyên nghiệp iDecal" class="rounded-3xl shadow-2xl relative z-10 border-8 border-gray-800/50" />
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
        <div class="relative">
          <div class="absolute -inset-4 bg-gray-100 blur-2xl rounded-full"></div>
          <img 
            src="/images/about-idecal.webp" 
            alt="Về iDecal - Chuyên gia decal dán kính" 
            class="rounded-[40px] shadow-2xl relative z-10 w-full h-[450px] object-cover border-8 border-white"
          />
        </div>
        <div class="relative z-10">
          <h2 class="text-secondary font-bold uppercase tracking-widest text-sm mb-3">Về chúng tôi</h2>
          <h3 class="text-4xl font-heading font-black text-secondary mb-6">Chuyên gia Decal & Phim cách nhiệt hàng đầu</h3>
          <p class="text-gray-600 mb-6 text-lg leading-relaxed">
            Với nhiều năm kinh nghiệm, <strong>iDecal</strong> tự hào là đơn vị tiên phong cung cấp giải pháp dán decal kính văn phòng, phim nội thất và quảng cáo ô tô chuyên nghiệp.
          </p>
          <ul class="space-y-4 mb-8">
            <li class="flex items-center gap-3 font-bold text-secondary">
              <span class="bg-primary text-secondary p-1 rounded-md text-xs">✓</span> Thi công nhanh chóng, sạch sẽ
            </li>
            <li class="flex items-center gap-3 font-bold text-secondary">
              <span class="bg-primary text-secondary p-1 rounded-md text-xs">✓</span> Vật liệu chính hãng, độ bền cao
            </li>
            <li class="flex items-center gap-3 font-bold text-secondary">
              <span class="bg-primary text-secondary p-1 rounded-md text-xs">✓</span> Khảo sát và tư vấn tận nơi miễn phí
            </li>
          </ul>
          <a href="/gioi-thieu" class="inline-block bg-secondary text-white px-8 py-4 rounded-xl font-black hover:bg-gray-800 transition-all shadow-lg hover:-translate-y-1">
            TÌM HIỂU THÊM
          </a>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gray-50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
          <div class="max-w-2xl">
            <h2 class="text-secondary font-bold uppercase tracking-widest text-sm mb-3">Thực tế thi công</h2>
            <h3 class="text-3xl md:text-5xl font-heading font-black text-secondary leading-tight">Dự án tiêu biểu bởi iDecal</h3>
          </div>
          <a href="/du-an" class="text-secondary font-bold hover:text-primary flex items-center gap-2 mb-2 transition-colors">
            Xem tất cả dự án 
            <span>→</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="group cursor-pointer">
            <div class="relative overflow-hidden rounded-2xl mb-4">
              <img src="/images/project-vinhomes.webp" alt="Thi công decal tại Vinhomes" class="w-full h-72 object-cover group-hover:scale-110 transition-transform duration-500" />
              <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
                <p class="text-white text-sm font-medium">Cải tạo tủ bếp căn hộ Vinhomes Grand Park</p>
              </div>
            </div>
            <h4 class="text-xl font-bold text-secondary">Vinhomes Grand Park</h4>
            <p class="text-gray-500 text-sm">TP. Thủ Đức</p>
          </div>
          <div class="group cursor-pointer">
            <div class="relative overflow-hidden rounded-2xl mb-4">
              <img src="/images/project-office.webp" alt="Decal văn phòng hiện đại" class="w-full h-72 object-cover group-hover:scale-110 transition-transform duration-500" />
              <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
                <p class="text-white text-sm font-medium">Dán Decal mờ 3D riêng tư cho phòng họp</p>
              </div>
            </div>
            <h4 class="text-xl font-bold text-secondary">Văn phòng Coworking Space</h4>
            <p class="text-gray-500 text-sm">Quận 1, TP.HCM</p>
          </div>
          <div class="group cursor-pointer">
            <div class="relative overflow-hidden rounded-2xl mb-4">
              <img src="/images/project-elevator.webp" alt="Dán film thang máy" class="w-full h-72 object-cover group-hover:scale-110 transition-transform duration-500" />
              <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
                <p class="text-white text-sm font-medium">Dán Film cabin thang máy cao cấp</p>
              </div>
            </div>
            <h4 class="text-xl font-bold text-secondary">Tòa nhà văn phòng</h4>
            <p class="text-gray-500 text-sm">Quận 3, TP.HCM</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-secondary font-bold uppercase tracking-widest text-sm text-center mb-3">Hỗ trợ khách hàng</h2>
        <h3 class="text-3xl md:text-4xl font-heading font-black text-center text-secondary mb-12 uppercase">Câu hỏi thường gặp</h3>
        <div class="space-y-4">
          <details class="group bg-gray-50 rounded-2xl border border-gray-200 overflow-hidden" open>
            <summary class="flex justify-between items-center p-6 cursor-pointer list-none font-bold text-secondary">
              iDecal phục vụ những khu vực nào?
              <span class="transition group-open:rotate-180">▼</span>
            </summary>
            <div class="px-6 pb-6 text-gray-600 border-t border-gray-100 pt-4">
              Chúng tôi thi công trọng tâm tại: <strong>TP.HCM, Bình Dương, Bà Rịa – Vũng Tàu, Đồng Nai, Long An...</strong> và các tỉnh lân cận.
            </div>
          </details>

          <details class="group bg-gray-50 rounded-2xl border border-gray-200 overflow-hidden">
            <summary class="flex justify-between items-center p-6 cursor-pointer list-none font-bold text-secondary">
              Decal mờ 3D có độ che chắn như thế nào?
              <span class="transition group-open:rotate-180">▼</span>
            </summary>
            <div class="px-6 pb-6 text-gray-600 border-t border-gray-100 pt-4">
              Decal mờ 3D của iDecal có vân nổi tinh tế, giúp che mờ khoảng <strong>20-30%</strong>, đảm bảo sự riêng tư nhưng vẫn lấy được ánh sáng tự nhiên.
            </div>
          </details>

          <details class="group bg-gray-50 rounded-2xl border border-gray-200 overflow-hidden">
            <summary class="flex justify-between items-center p-6 cursor-pointer list-none font-bold text-secondary">
              Thời gian bảo hành công trình bao lâu?
              <span class="transition group-open:rotate-180">▼</span>
            </summary>
            <div class="px-6 pb-6 text-gray-600 border-t border-gray-100 pt-4">
              iDecal bảo hành kỹ thuật <strong>2 năm</strong> cho các lỗi bong tróc tự nhiên. Đối với các dòng phim cách nhiệt cao cấp, thời gian bảo hành lên đến 5 năm.
            </div>
          </details>
        </div>
      </div>
    </section>

    <section class="py-12 bg-gray-50">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <div class="bg-white p-10 md:p-16 rounded-[50px] shadow-xl border border-gray-200 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-bl-full"></div>
          <h3 class="text-2xl md:text-3xl font-heading font-black text-secondary mb-10 italic underline decoration-primary underline-offset-8">
            Liên hệ chuyên gia iDecal
          </h3>
          <div class="bg-gray-50 p-8 rounded-3xl border border-dashed border-gray-300 mb-10 inline-block w-full max-w-md">
             <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-2">Đường dây nóng 24/7</p>
             <a href="tel:0866077040" class="text-4xl md:text-5xl font-black text-secondary hover:text-primary transition-colors tracking-tight">
               0866.077.040
             </a>
          </div>
          <a href="/lien-he" class="block w-full max-w-md mx-auto bg-secondary text-white font-black py-5 rounded-2xl hover:bg-gray-800 transition-all shadow-xl text-xl uppercase tracking-wider">
            ĐẶT THIẾT KẾ MẪU NGAY
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
