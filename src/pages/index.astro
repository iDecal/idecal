---
import Layout from '../layouts/Layout.astro';

const title = "iDecal.vn | Decal dán kính cách nhiệt & Decal mờ trang trí chuyên nghiệp";
const description = "Chuyên gia cung cấp giải pháp decal dán kính, phim cách nhiệt nhà kính, văn phòng tại TP. Thủ Đức, TP.HCM & Bình Dương. Đối tác của 200+ công ty nội thất.";
---

<Layout title={title} description={description}>
  <main class="bg-white">
    <section class="relative bg-white text-secondary py-20 lg:py-32 overflow-hidden border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center relative z-10">
        <div>
          <span class="inline-block bg-primary/10 text-secondary px-4 py-1.5 rounded-full text-xs font-bold mb-6 uppercase tracking-wider">
            Đối tác của 200+ công ty nội thất
          </span>
          <h1 class="text-4xl md:text-5xl font-heading font-black leading-tight mb-6 uppercase tracking-tighter">
            iDecal – Decal dán kính <span class="text-primary italic underline decoration-primary decoration-2 underline-offset-4">cách nhiệt</span> & Decal mờ trang trí
          </h1>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed max-w-xl">
            Giải pháp hàng đầu cho không gian văn phòng và căn hộ. Chúng tôi cam kết chất lượng vật liệu chính hãng và kỹ thuật thi công sắc nét.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm font-bold text-secondary">
            <div class="flex items-center gap-2"><span class="text-primary text-xl">✓</span> Thi công chuyên nghiệp</div>
            <div class="flex items-center gap-2"><span class="text-primary text-xl">✓</span> Bảo hành 2-5 năm</div>
            <div class="flex items-center gap-2"><span class="text-primary text-xl">✓</span> Giá cạnh tranh tận xưởng</div>
          </div>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 bg-primary/5 blur-3xl rounded-full"></div>
          <img src="/Dich-vu-decal-dan-kinh-cach-nhiet.webp" alt="Thi công decal dán kính chuyên nghiệp iDecal" class="rounded-3xl shadow-xl relative z-10 border-8 border-white" />
          <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl z-20 hidden md:block">
            <p class="text-4xl font-black text-secondary">96.5%</p>
            <p class="text-gray-500 text-xs uppercase font-bold tracking-tighter">Khách hàng hài lòng</p>
          </div>
        </div>
      </div>
    </section>



    <section class="py-12 bg-gray-50 border-y border-gray-100">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-center text-gray-500 text-sm font-bold uppercase tracking-widest mb-8">Vật liệu từ các thương hiệu hàng đầu</p>
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16">
          <img src="/images/logos/3m.svg" alt="3M" class="h-8 md:h-10 grayscale hover:grayscale-0 transition-all opacity-70 hover:opacity-100" />
          <img src="/images/logos/avery.svg" alt="Avery" class="h-8 md:h-10 grayscale hover:grayscale-0 transition-all opacity-70 hover:opacity-100" />
          <img src="/images/logos/llumar.svg" alt="Llumar" class="h-8 md:h-10 grayscale hover:grayscale-0 transition-all opacity-70 hover:opacity-100" />
          <img src="/images/logos/oracal.svg" alt="Oracal" class="h-8 md:h-10 grayscale hover:grayscale-0 transition-all opacity-70 hover:opacity-100" />
          <img src="/images/logos/nk.svg" alt="NK Film" class="h-8 md:h-10 grayscale hover:grayscale-0 transition-all opacity-70 hover:opacity-100" />
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-secondary font-bold uppercase tracking-widest text-sm mb-3">Dịch vụ thế mạnh</h2>
          <h3 class="text-3xl md:text-5xl font-heading font-black text-secondary mb-4">Giải pháp Decal dán kính trọn gói</h3>
          <p class="text-gray-600 text-lg">Chúng tôi cung cấp giải pháp trang trí kính & Dịch vụ decal dán kính cách nhiệt toàn diện</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/decal-mo-3d.webp" alt="Decal mờ 3D iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Decal mờ 3D</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Thiết kế vân nổi sống động. Tạo chiều sâu, nét độc đáo sang trọng cho kính. Độ trong suốt 20-30% tạo sự riêng tư tinh tế.</p>
              <a href="/decal-mo-3d" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết sản phẩm <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/phim-cach-nhiet.webp" alt="Phim cách nhiệt iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Phim cách nhiệt</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">3M, Llumar: Cách nhiệt 80%, chống 99% UV. Giải pháp làm giảm ánh sáng, chống chói, bảo vệ kính và sức khỏe tối ưu.</p>
              <a href="/phim-cach-nhiet" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết thêm <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/decal-cat-chu.webp" alt="Decal cắt chữ iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Decal cắt chữ</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Cắt decal theo yêu cầu – Sắc nét, bền màu, bám dính tốt trên mọi bề mặt phẳng. Logo công ty, Sticker nhãn dán.</p>
              <a href="/decal-cat-chu" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết thêm <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/phim-dan-noi-that.webp" alt="Phim dán nội thất iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Phim dán nội thất</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Tái tạo không gian. Mẫu film đa dạng từ vân gỗ, đá, kim loại. Làm mới đồ nội thất nhanh chóng và tiết kiệm.</p>
              <a href="/film-noithat" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết thêm <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/decal-quang-cao.webp" alt="Decal quảng cáo iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Decal quảng cáo</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Giải pháp in ấn Decal khổ lớn. Phù hợp dán tường, dán kính, dán xe. Chất liệu PP, Vinyl bền màu.</p>
              <a href="/decal-quang-cao" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết thêm <span>→</span></a>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all border border-gray-200 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src="/images/decal-van-phong.webp" alt="Decal văn phòng iDecal" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-heading font-black mb-3 text-secondary">Decal văn phòng</h3>
              <p class="text-gray-600 text-sm mb-6 leading-relaxed">Tạo sự riêng tư, chuyên nghiệp cho văn phòng. Che mờ kính, chống lóa và nổi bật Logo nhận diện.</p>
              <a href="/decal-van-phong" class="text-secondary font-bold text-sm flex items-center gap-2 group-hover:text-primary transition-colors">Chi tiết thêm <span>→</span></a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gray-100">
      <div class="max-w-7xl mx-auto px-6 text-center mb-16">
        <h2 class="text-secondary font-bold uppercase tracking-widest text-sm mb-3">Quy trình làm việc</h2>
        <h3 class="text-3xl md:text-4xl font-heading font-black text-secondary">Từ ý tưởng đến hiện thực</h3>
      </div>
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-3 gap-8">
        <div class="p-10 bg-white rounded-3xl shadow-sm border border-gray-200 relative overflow-hidden group">
          <div class="text-gray-100 font-black text-8xl absolute -top-4 -right-2 z-0">01</div>
          <div class="relative z-10">
            <h3 class="text-2xl font-heading font-black mb-4 uppercase text-secondary group-hover:text-primary transition-colors">Thiết kế độc quyền</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Đội ngũ iDecal hỗ trợ tùy chỉnh mẫu, chèn logo, căn chỉnh kích thước chuẩn xác. Đảm bảo nhận diện thương hiệu.</p>
          </div>
        </div>
        <div class="p-10 bg-white rounded-3xl shadow-sm border border-gray-200 relative overflow-hidden group">
          <div class="text-gray-100 font-black text-8xl absolute -top-4 -right-2 z-0">02</div>
          <div class="relative z-10">
            <h3 class="text-2xl font-heading font-black mb-4 uppercase text-secondary group-hover:text-primary transition-colors">In ấn sắc nét</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Hệ thống máy in hiện đại, mực Eco-Solvent bền màu. Đảm bảo hình ảnh sắc nét trên mọi chất liệu.</p>
          </div>
        </div>
        <div class="p-10 bg-white rounded-3xl shadow-sm border border-gray-200 relative overflow-hidden group">
          <div class="text-gray-100 font-black text-8xl absolute -top-4 -right-2 z-0">03</div>
          <div class="relative z-10">
            <h3 class="text-2xl font-heading font-black mb-4 uppercase text-secondary group-hover:text-primary transition-colors">Thi công tận tâm</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Đội thợ lành nghề trực tiếp thi công. Đảm bảo bề mặt phẳng mịn, không bọt khí, vệ sinh sạch sẽ.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center mb-24">
        <div class="relative">
          <div class="absolute -inset-4 bg-primary/10 blur-2xl rounded-full"></div>
          <img src="/images/about-idecal.webp" alt="Về iDecal" class="rounded-[40px] shadow-2xl relative z-10 w-full h-[450px] object-cover border-8 border-white" />
        </div>
        <div>
          <h2 class="text-4xl font-heading font-black text-secondary mb-6">Chuyên gia Decal & Phim cách nhiệt hàng đầu</h2>
          <p class="text-gray-600 mb-6 text-lg leading-relaxed">Với hơn nhiều năm kinh nghiệm, <strong>iDecal</strong> tự hào là đối tác tin cậy của hơn 200+ đơn vị nội thất và hàng ngàn khách hàng cá nhân.</p>
          <ul class="space-y-4 mb-8 font-bold text-secondary">
            <li class="flex items-center gap-3"><span class="bg-primary text-secondary p-1 rounded-md text-xs">✓</span> Thi công nhanh chóng, sạch sẽ</li>
            <li class="flex items-center gap-3"><span class="bg-primary text-secondary p-1 rounded-md text-xs">✓</span> Vật liệu chính hãng 100%</li>
          </ul>
          <a href="/gioi-thieu" class="inline-block bg-secondary text-white px-8 py-4 rounded-xl font-black hover:bg-gray-800 transition-all shadow-lg hover:-translate-y-1">TÌM HIỂU THÊM</a>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-end mb-12">
          <h3 class="text-3xl font-heading font-black text-secondary uppercase">Dự án tiêu biểu</h3>
          <a href="/du-an" class="text-secondary font-bold hover:text-primary transition-colors">Xem tất cả →</a>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="group"><div class="overflow-hidden rounded-2xl mb-4"><img src="/images/project-the-hive.webp" class="w-full h-64 object-cover group-hover:scale-110 transition-duration-500" /></div><h4 class="font-bold text-secondary">The Hive - Thảo Điền</h4><p class="text-sm text-gray-500">Quận 2, TP.HCM</p></div>
          <div class="group"><div class="overflow-hidden rounded-2xl mb-4"><img src="/images/project-toyota.webp" class="w-full h-64 object-cover group-hover:scale-110 transition-duration-500" /></div><h4 class="font-bold text-secondary">Showroom Toyota</h4><p class="text-sm text-gray-500">Bình Dương</p></div>
          <div class="group"><div class="overflow-hidden rounded-2xl mb-4"><img src="/images/project-office.webp" class="w-full h-64 object-cover group-hover:scale-110 transition-duration-500" /></div><h4 class="font-bold text-secondary">Văn phòng Coworking</h4><p class="text-sm text-gray-500">Quận 1, TP.HCM</p></div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h3 class="text-3xl font-heading font-black text-center text-secondary mb-12 uppercase">Câu hỏi thường gặp</h3>
        <div class="space-y-4">
          <details class="group bg-white rounded-2xl border border-gray-200" open>
            <summary class="p-6 cursor-pointer font-bold text-secondary flex justify-between">iDecal phục vụ khu vực nào? <span class="group-open:rotate-180 transition">▼</span></summary>
            <p class="px-6 pb-6 text-gray-600 border-t pt-4">Chúng tôi thi công trọng tâm tại: TP.HCM, Bình Dương, Đồng Nai, Long An...</p>
          </details>
          <details class="group bg-white rounded-2xl border border-gray-200">
            <summary class="p-6 cursor-pointer font-bold text-secondary flex justify-between">Decal mờ 3D có độ che chắn như thế nào? <span class="group-open:rotate-180 transition">▼</span></summary>
            <p class="px-6 pb-6 text-gray-600 border-t pt-4">Decal mờ 3D của iDecal giúp che mờ khoảng 20-30%, đảm bảo riêng tư tinh tế.</p>
          </details>
        </div>
      </div>
    </section>

    <section class="py-12 bg-white">
      <div class="max-w-5xl mx-auto px-6 text-center bg-gray-50 p-16 rounded-[50px] border border-gray-200 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-bl-full"></div>
        <h3 class="text-3xl font-heading font-black text-secondary mb-10 italic underline decoration-primary underline-offset-8">Tư vấn từ chuyên gia iDecal</h3>
        <a href="tel:0866077040" class="text-4xl md:text-5xl font-black text-secondary hover:text-primary transition-colors block mb-10">0866.077.040</a>
        <a href="/lien-he" class="inline-block bg-secondary text-white font-black px-12 py-5 rounded-2xl hover:bg-gray-800 transition-all shadow-xl uppercase tracking-widest">ĐẶT THIẾT KẾ MẪU NGAY</a>
      </div>
    </section>
  </main>
</Layout>
