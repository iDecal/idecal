---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Partners from '../components/Partners.astro';
import ServiceCard from '../components/ServiceCard.astro'; // Đã tạo từ lượt trước
import About from '../components/About.astro';
import Portfolio from '../components/Portfolio.astro';
import FAQ from '../components/FAQ.astro';

// Dữ liệu 6 dịch vụ chính
const services = [
  { title: "Phim Cách Nhiệt", description: "Cách nhiệt 80%, ngăn 99% UV cho nhà kính.", image: "/images/pcn.webp", link: "/phim-cach-nhiet" },
  { title: "Decal Mờ 3D", description: "Vân nổi sống động, độ mờ riêng tư 20-30%.", image: "/images/mo3d.webp", link: "/decal-mo-3d" },
  { title: "Decal Cắt Chữ", description: "Cắt CNC sắc nét Logo, Sticker thương hiệu.", image: "/images/cat.webp", link: "/decal-cat-chu" },
  { title: "Phim Nội Thất", description: "Làm mới bàn ghế, tủ kệ với vân gỗ, đá.", image: "/images/film.webp", link: "/film-noithat" },
  { title: "Decal Quảng Cáo", description: "In ấn PP, Vinyl khổ lớn chuyên nghiệp.", image: "/images/adv.webp", link: "/decal-quang-cao" },
  { title: "Decal Văn Phòng", description: "Giải pháp trang trí kính văn phòng trọn gói.", image: "/images/vp.webp", link: "/decal-van-phong" }
];
---

<Layout title="iDecal - Chuyên gia Decal & Phim Cách Nhiệt">
  <Layout title="iDecal - Dịch vụ decal chuyên nghiệp">
  <Hero 
    badge="THI CÔNG CHUYÊN NGHIỆP" 
    title="Giải pháp dán kính"
    highlight="Toàn diện"
    description="Chuyên thi công Decal mờ, Phim cách nhiệt và In ấn quảng cáo tại TP.HCM, Bình Dương, Quy Nhơn."
    image="/images/hero-decal.jpg" 
  />
  
  
  <Partners />

  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6 text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold text-secondary">6 Dịch vụ chính tại iDecal</h2>
    </div>
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map(s => <ServiceCard {...s} />)}
    </div>
  </section>

  <About />
  <Portfolio />
  <FAQ />
</Layout>
