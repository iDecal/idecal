---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  { q: "iDecal có hỗ trợ thiết kế file in không?", a: "Có, đội ngũ thiết kế của chúng tôi sẽ hỗ trợ tối ưu file in, kiểm tra độ phân giải và chỉnh sửa màu sắc chuẩn CMYK để đảm bảo bản in sắc nét nhất." },
  { q: "Loại decal nào phù hợp dán xe tải quảng cáo?", a: "Đối với xe tải, iDecal tư vấn sử dụng Decal sữa chuyên dụng hoặc Decal 3M cao cấp có độ bám dính cực cao và chịu được nắng mưa." },
  { q: "Thời gian in ấn và thi công mất bao lâu?", a: "Với các đơn hàng dưới 50m2, iDecal có thể hoàn thiện in ấn và thi công ngay trong 24h để kịp tiến độ của khách hàng." },
  { q: "Bản in decal quảng cáo có bị bay màu không?", a: "Chúng tôi sử dụng mực in UV Nhật Bản và cán thêm lớp màng bảo vệ, giúp màu sắc bền bỉ từ 2-5 năm ngoài trời." }
];
---

<Layout title="Thi Công Decal Quảng Cáo Chuyên Nghiệp | iDecal">
  
  <section class="py-24 bg-slate-900 text-white relative">
    <div class="container grid lg:grid-cols-2 gap-12 items-center">
      <div class="animate-fade-up">
        <h6 class="text-primary tracking-[0.3em]">Branding Solution</h6>
        <h1 class="text-white">In Ấn & Thi Công Decal Quảng Cáo</h1>
        <p class="text-slate-400 text-lg">Dịch vụ trọn gói từ thiết kế đến thi công với các dòng vật liệu <strong>Decal sữa, Decal trong, Decal 3M</strong> cao cấp.</p>
        <div class="mt-8 flex gap-4">
          <a href="#" class="btn-primary-solid">Nhận báo giá</a>
        </div>
      </div>
      <div class="relative"><img src="/images/hero-qc.webp" class="img-brand w-full h-[400px]" alt="Decal quảng cáo" /></div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h6>Năng lực iDecal</h6>
        <h2>Dịch vụ In & Thiết kế</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="service-card-brand bg-slate-50/50 border-none"> <h4 class="!mb-4 text-primary">In Kỹ Thuật Số</h4>
          <p class="text-sm">In <strong>PP bồi Formex</strong>, <strong>Decal trong</strong> cán màng bóng/mờ cho độ bền vượt trội.</p>
        </div>
        <div class="service-card-brand bg-slate-50/50 border-none">
          <h4 class="!mb-4 text-primary">Decal Xe Tải</h4>
          <p class="text-sm">Sử dụng <strong>Decal 3M</strong> chuyên dụng, bám dính cực tốt, không để lại keo khi gỡ.</p>
        </div>
        <div class="service-card-brand bg-slate-50/50 border-none">
          <h4 class="!mb-4 text-primary">Biển Hiệu & POSM</h4>
          <p class="text-sm">Thi công <strong>Decal lưới</strong>, <strong>Decal cắt chữ</strong> bảng hiệu chuyên nghiệp.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-blue-50/40 border-y border-blue-100/50">
    <div class="container grid lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1">
        <img src="/images/tech.webp" class="img-brand shadow-blue-900/5" alt="Công nghệ in" />
      </div>
      <div class="order-1 lg:order-2">
        <h2>Công nghệ & Vật liệu</h2>
        <p>Chúng tôi sử dụng <strong>mực UV Nhật Bản</strong> và các dòng <strong>Decal chính hãng</strong> giúp bản in sắc nét, không bong tróc mép sau thời gian dài sử dụng.</p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-50/80">
    <div class="container">
      <div class="text-center mb-16">
        <h6>Hỏi đáp</h6>
        <h2>Giải đáp thắc mắc</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-x-12 gap-y-6">
        {faqs.map((faq) => (
          <div class="faq-item">
            <details class="faq-details group lg:pointer-events-none" open>
              <summary class="flex items-center justify-between py-4 font-bold text-secondary group-open:text-primary px-2">
                <span class="flex gap-4 items-start">
                  <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/10 text-primary text-[10px] flex items-center justify-center font-black">Q</span>
                  <span class="text-secondary">{faq.q}</span>
                </span>
              </summary>
              <div class="flex gap-4 p-5 bg-white rounded-2xl animate-fadeIn items-start shadow-sm border border-slate-100">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-slate-100 text-secondary/40 text-[10px] flex items-center justify-center font-black">A</span>
                <p class="text-text-muted text-sm leading-relaxed !mb-0">{faq.a}</p>
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fadeIn { animation: fadeIn 0.4s ease-out forwards; }
  summary::-webkit-details-marker { display: none; }
  @media (min-width: 1024px) { .faq-details { display: block !important; } .faq-details div { display: flex !important; } }
  @media (max-width: 1023px) { 
    .faq-details div { display: none; } 
    .faq-details[open] div { display: flex; } 
    .faq-details[open] { @apply mb-4; }
  }
</style>

<script>
  function setupFAQ() {
    const isDesktop = window.innerWidth >= 1024;
    document.querySelectorAll('.faq-details').forEach(el => {
      if (isDesktop) el.setAttribute('open', '');
      else el.removeAttribute('open');
    });
  }
  setupFAQ();
  window.addEventListener('resize', setupFAQ);
</script>
