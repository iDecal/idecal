---
import Layout from '../layouts/Layout.astro';

// Dữ liệu giả lập cho các công trình đã thực hiện
const projects = [
  {
    title: "Dán Decal Quảng Cáo Chuỗi Xe Tải Coca-Cola",
    type: "Decal 3M Cao Cấp",
    image: "/images/congtrinh-xetai-1.webp",
    size: "250m2"
  },
  {
    title: "Thi Công Decal Lưới & Cắt Chữ Showroom Toyota",
    type: "Decal Lưới / Cắt Vi Tính",
    image: "/images/congtrinh-showroom-1.webp",
    size: "80m2"
  },
  {
    title: "In POSM & Standee Quảng Cáo Sự Kiện VinFast",
    type: "In PP Bồi Formex",
    image: "/images/congtrinh-posm-1.webp",
    size: "150m2"
  }
];
---

<Layout title="Thi Công & In Ấn Decal Quảng Cáo Chuyên Nghiệp | iDecal">
  
  <section class="py-24 bg-slate-900 text-white relative overflow-hidden">
    <div class="container grid lg:grid-cols-2 gap-12 items-center relative z-10">
      
      <div class="animate-fade-up">
        <h6 class="text-slate-300 tracking-[0.3em] font-bold">Giải pháp thương hiệu</h6>
        
        <h1 class="text-white !important leading-tight">In Ấn & Thi Công Decal Quảng Cáo Khổ Lớn</h1>
        
        <p class="text-slate-300 text-lg leading-relaxed">
          Tối ưu diện mạo kinh doanh với dịch vụ trọn gói từ <strong>thiết kế</strong>, <strong>in ấn</strong> sắc nét đến <strong>thi công</strong> chuẩn xác trên mọi bề mặt: Xe tải, Vách kính, Bảng hiệu, Standee.
        </p>
        
        <div class="flex flex-wrap gap-4 mt-8">
          <a href="#quote" class="btn-primary-solid">Liên hệ báo giá ngay</a>
          <a href="#portfolio" class="btn-idecal-bold text-white border-white transition-colors hover:text-primary hover:border-primary">Xem công trình thực tế</a>
        </div>
      </div>
      
      <div class="relative group">
        <div class="absolute -inset-10 bg-primary/20 rounded-full blur-3xl opacity-50"></div>
        <img 
          src="/images/hero-decal-quangcao.webp" 
          alt="Thi công decal quảng cáo trên xe tải" 
          class="img-brand w-full h-[450px] object-cover relative z-10 transition-transform duration-500 group-hover:scale-105" 
        />
      </div>
    </div>
    
    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-slate-900 via-slate-900/10 to-transparent"></div>
  </section>

  <section id="portfolio" class="py-24 bg-white border-b border-slate-100/50">
    <div class="container">
      <div class="text-center mb-16">
        <h6 class="text-primary tracking-widest uppercase">Uy tín đã được khẳng định</h6>
        <h2>Công trình Decal Quảng Cáo tiêu biểu</h2>
        <p class="max-w-2xl mx-auto italic">Chúng tôi tự hào là đối tác tin cậy của hàng trăm doanh nghiệp tại TP.HCM và các tỉnh lân cận.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {projects.map((project) => (
          <div class="group overflow-hidden rounded-[2rem] bg-white shadow-card transition-all duration-300 hover:shadow-brand hover:-translate-y-2">
            <div class="overflow-hidden h-64">
              <img 
                src={project.image} 
                alt={project.title} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              />
            </div>
            
            <div class="p-6">
              <div class="flex items-center justify-between gap-3 mb-2">
                <span class="inline-block px-3 py-1 text-xs font-bold text-primary bg-primary/10 rounded-full">{project.type}</span>
                <span class="text-xs text-text-muted">Khối lượng: {project.size}</span>
              </div>
              <h4 class="text-base text-secondary !mb-0 group-hover:text-primary transition-colors">{project.title}</h4>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hiệu ứng FadeIn cho Hero */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
