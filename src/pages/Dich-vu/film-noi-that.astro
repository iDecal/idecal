---
import Layout from '../../layouts/Layout.astro';

const interiorFilms = [
  { title: "Vân Gỗ Cao Cấp", desc: "Tái tạo bề mặt tủ bếp, bàn ghế với đường vân sồi, óc chó chân thực.", brands: "Infeel, Octki", image: "/images/noi-that/film-van-go.webp" },
  { title: "Vân Đá Cẩm Thạch", desc: "Biến mặt bàn, quầy bar thành đá Marble sang trọng, chịu nhiệt tốt.", brands: "GYMak, Infeel", image: "/images/noi-that/film-gia-da.webp" },
  { title: "Vân Đơn Sắc (Solid)", desc: "Phong cách Minimalist với các tông màu trung tính nhám mờ hiện đại.", brands: "Octki", image: "/images/noi-that/film-solid.webp" },
  { title: "Vân Bê Tông & Xi Măng", desc: "Hiệu ứng Industrial mạnh mẽ cho vách tường và kệ trang trí.", brands: "Infeel", image: "/images/noi-that/film-be-tong.webp" },
  { title: "Vân Kim Loại & Xước", desc: "Làm mới thang máy, tủ lạnh với bề mặt xước kim loại đẳng cấp.", brands: "Octki", image: "/images/noi-that/film-kim-loai.webp" },
  { title: "Vân Tráng Gương", desc: "Bề mặt bóng gương sâu, phù hợp cho các điểm nhấn decor sang trọng.", brands: "GYMak", image: "/images/noi-that/film-trang-guong.webp" },
  { title: "Vân Vải & Da", desc: "Tạo cảm giác ấm cúng, mềm mại cho tủ quần áo và tab đầu giường.", brands: "Infeel", image: "/images/noi-that/film-van-vai.webp" },
  { title: "Vân Bóng Mờ (Satin)", desc: "Độ bóng vừa phải, chống bám vân tay, dễ dàng vệ sinh lau chùi.", brands: "Octki", image: "/images/noi-that/film-bong-mo.webp" }
];

const applications = [
  { area: "Tủ Bếp & Mặt Bàn", detail: "Chống thấm nước, chịu nhiệt độ cao, bảo vệ cốt gỗ bên trong khỏi ẩm mốc." },
  { area: "Cửa & Thang Máy", detail: "Thay đổi màu sắc cửa ra vào, cửa phòng ngủ nhanh chóng không cần thay mới." },
  { area: "Tủ Áo & Kệ Tivi", detail: "Làm mới nội thất phòng ngủ, phòng khách đồng bộ theo phong cách thiết kế." },
  { area: "Vách Tường & Cột", detail: "Giải pháp thay thế sơn hoặc ốp đá nội thất với chi phí tiết kiệm." }
];

const faqs = [
  { q: "Dán Film nội thất có bền không?", a: "Sản phẩm có độ bền trung bình từ 5-10 năm. iDecal bảo hành bong tróc 2 năm cho mọi công trình." },
  { q: "Có dán được trên bề mặt cũ, bong tróc không?", a: "Được. Kỹ thuật viên của chúng tôi sẽ xử lý bề mặt (xả nhám, trám trét) phẳng mịn trước khi dán." },
  { q: "Film có chịu được nước và nhiệt không?", a: "Hoàn toàn có. Film nội thất cao cấp có lớp phủ chống xước, chịu được nước và nhiệt độ phòng bếp thông thường." }
];
---

<Layout title="Film Nội Thất - Furniture Wrap | Làm Mới Không Gian Không Cần Thay Đồ">

  <section class="py-24 bg-slate-900 relative overflow-hidden">
    <div class="container grid lg:grid-cols-2 gap-12 items-center relative z-10">
      <div class="animate-fade-up">
        <h6 class="text-primary tracking-[0.3em] font-bold uppercase">Interior Transformation</h6>
        <h1 class="text-white !important">Film Nội Thất - Giải Pháp "Refresh" Không Gian Đẳng Cấp</h1>
        <p class="text-slate-400 text-lg">
          Thay đổi diện mạo <strong>tủ bếp, cửa, thang máy</strong> bằng Film cao cấp Octki, Infeel. Thi công sạch sẽ, không bụi bẩn, không mùi sơn, hoàn thiện ngay trong ngày.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="#samples" class="btn-primary-solid">Xem bảng màu thực tế</a>
          <a href="https://zalo.me/090xxxxxxx" class="btn-idecal-bold text-white border-white hover:text-primary transition-all">Báo giá qua Zalo</a>
        </div>
      </div>
      <div class="relative">
        <div class="absolute -inset-10 bg-primary/10 rounded-full blur-3xl opacity-40"></div>
        <img src="/images/noi-that/hero-furniture.webp" alt="Dán film nội thất tủ bếp" class="img-brand w-full h-[500px] object-cover relative z-10 border-l-8 border-primary" />
      </div>
    </div>
  </section>

  <section id="samples" class="py-24 bg-slate-50">
    <div class="container">
      <div class="text-center mb-16">
        <h6 class="text-primary font-black uppercase tracking-widest text-[10px]">Premium Catalog</h6>
        <h2 class="mt-4">Bộ Sưu Tập Film Nội Thất 2026</h2>
      </div>
      <div class="grid md:grid-cols-4 gap-6">
        {interiorFilms.map((film) => (
          <div class="bg-white rounded-[2rem] overflow-hidden group shadow-sm hover:shadow-xl transition-all border border-slate-100">
            <div class="h-48 overflow-hidden">
              <img src={film.image} alt={film.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            </div>
            <div class="p-6">
              <p class="text-[9px] font-black text-primary uppercase mb-2">{film.brands}</p>
              <h4 class="text-sm font-bold text-secondary mb-2">{film.title}</h4>
              <p class="text-[11px] text-slate-500 leading-relaxed">{film.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="grid grid-cols-2 gap-4">
          <img src="/images/noi-that/app-1.webp" class="rounded-3xl h-64 w-full object-cover" alt="Dán tủ bếp" />
          <img src="/images/noi-that/app-2.webp" class="rounded-3xl h-64 mt-8 w-full object-cover" alt="Dán thang máy" />
        </div>
        <div>
          <h2 class="mb-8">Ứng dụng đa dạng trong nội thất</h2>
          <div class="space-y-6">
            {applications.map(app => (
              <div class="flex gap-4 p-4 rounded-2xl hover:bg-blue-50 transition-colors border border-transparent hover:border-blue-100">
                <div class="text-primary font-bold">✨</div>
                <div>
                  <h4 class="text-base font-bold text-secondary">{app.area}</h4>
                  <p class="text-xs text-slate-500 mt-1">{app.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-50">
    <div class="container max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="mb-4">Câu hỏi thường gặp</h2>
        <p class="text-slate-500">Giải đáp các thắc mắc về kỹ thuật và bảo hành dán Film nội thất.</p>
      </div>
      <div class="space-y-4">
        {faqs.map(faq => (
          <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
            <h4 class="text-sm font-bold text-secondary mb-2">Q: {faq.q}</h4>
            <p class="text-xs text-slate-500 leading-relaxed">A: {faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-900 rounded-t-[4rem]">
    <div class="container text-center text-white">
      <h2 class="text-white !important mb-6">Bạn cần làm mới không gian?</h2>
      <p class="text-slate-400 mb-10 max-w-2xl mx-auto text-sm">
        Đừng vội thay mới đồ nội thất đắt đỏ. Hãy để iDecal mang mẫu Film đến tận nhà đo đạc và tư vấn giải pháp tối ưu nhất cho bạn.
      </p>
      <div class="flex justify-center gap-6">
        <a href="tel:090xxxxxxx" class="btn-primary-solid">Hotline: 090x.xxx.xxx</a>
        <a href="https://zalo.me/090xxxxxxx" class="px-8 py-3 bg-white text-secondary font-bold rounded-brand hover:bg-primary hover:text-white transition-all">Chat Zalo ngay</a>
      </div>
    </div>
  </section>

</Layout>
