---
import Layout from '../../layouts/Layout.astro';

// Dữ liệu mẫu (Sau này bạn có thể lấy từ Content Collections của Astro)
const allPosts = [
  {
    title: "Cách chọn phim cách nhiệt phù hợp cho chung cư",
    excerpt: "Hướng dẫn chi tiết cách phân biệt các dòng phim cách nhiệt 3M, Llumar và cách chọn độ xuyên sáng...",
    category: "Kiến thức",
    image: "/images/blog-1.webp",
    date: "20/04/2026",
    slug: "chon-phim-cach-nhiet-chung-cu"
  },
  {
    title: "Dự án dán decal mờ tại tòa nhà Landmark 81",
    excerpt: "Thi công hơn 500m2 decal mờ 3D vân nổi cho hệ thống văn phòng cao cấp, đảm bảo sự riêng tư tuyệt đối.",
    category: "Dự án",
    image: "/images/blog-2.webp",
    date: "15/04/2026",
    slug: "du-an-landmark-81"
  },
  {
    title: "Ưu đãi dán kính nhà xưởng tại Bình Dương tháng 5",
    excerpt: "Chương trình khuyến mãi cực lớn cho các doanh nghiệp tại KCN VSIP, Sóng Thần. Giảm ngay 15% chi phí.",
    category: "Khuyến mãi",
    image: "/images/blog-3.webp",
    date: "10/04/2026",
    slug: "khuyen-mai-binh-duong"
  }
];

const categories = ["Tất cả", "Kiến thức", "Dự án", "Khuyến mãi"];
---

<Layout title="Blog iDecal | Kiến thức & Dự án thi công decal">
  <main class="bg-white pt-20 pb-24">
    <div class="max-w-7xl mx-auto px-6 mb-16">
      <div class="text-center max-w-2xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-secondary mb-4">Tin tức & Chia sẻ</h1>
        <p class="text-slate-500 text-sm lowercase tracking-wide">
          cập nhật những dự án mới nhất và kiến thức chuyên ngành decal dán kính
        </p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 mb-12">
      <div class="flex flex-wrap justify-center gap-3">
        {categories.map((cat) => (
          <button 
            class={`filter-btn px-6 py-2 rounded-full border-2 text-sm font-bold transition-all
              ${cat === "Tất cả" 
                ? "bg-secondary border-secondary text-white shadow-lg shadow-secondary/20" 
                : "border-slate-100 text-slate-500 hover:border-primary hover:text-primary"}`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6">
      <div id="blog-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
        {allPosts.map((post) => (
          <article class="post-card bg-white group cursor-pointer" data-category={post.category}>
            <div class="relative aspect-video rounded-2xl overflow-hidden mb-6 border border-slate-50">
              <img 
                src={post.image} 
                alt={post.title} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
              />
              <span class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-lg text-[10px] font-black uppercase text-primary tracking-tighter">
                {post.category}
              </span>
            </div>
            
            <div class="space-y-3">
              <p class="text-slate-400 text-xs font-medium">{post.date}</p>
              <h2 class="text-xl font-bold text-secondary group-hover:text-primary transition-colors leading-snug">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="text-slate-500 text-sm line-clamp-2 leading-relaxed">
                {post.excerpt}
              </p>
              <a href={`/blog/${post.slug}`} class="inline-block pt-2 text-primary font-bold text-xs uppercase tracking-widest hover:translate-x-1 transition-transform">
                Xem chi tiết →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  const filterButtons = document.querySelectorAll('.filter-btn');
  const postCards = document.querySelectorAll('.post-card');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');

      // Cập nhật giao diện nút bấm
      filterButtons.forEach(b => {
        b.classList.remove('bg-secondary', 'border-secondary', 'text-white', 'shadow-lg', 'shadow-secondary/20');
        b.classList.add('border-slate-100', 'text-slate-500');
      });
      btn.classList.add('bg-secondary', 'border-secondary', 'text-white', 'shadow-lg', 'shadow-secondary/20');
      btn.classList.remove('border-slate-100', 'text-slate-500');

      // Lọc bài viết
      postCards.forEach(card => {
        const cardCat = card.getAttribute('data-category');
        if (category === "Tất cả" || cardCat === category) {
          (card as HTMLElement).style.display = 'block';
          (card as HTMLElement).classList.add('animate-fadeIn');
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.4s ease-out forwards;
  }
</style>
