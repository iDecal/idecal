---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Tự động lấy tất cả bài viết và sắp xếp theo ngày mới nhất
const allPosts = await getCollection('blog');
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ["Tất cả", "Kiến thức", "Dự án", "Khuyến mãi"];
---

<Layout title="Blog iDecal | Kiến thức & Dự án">
  <main class="bg-white pt-20 pb-24">
    <div class="max-w-7xl mx-auto px-6 mb-16 text-center">
      <h1 class="text-4xl font-bold text-secondary mb-4">Tin tức & Chia sẻ</h1>
      <p class="text-slate-500 text-sm lowercase">khám phá các dự án và kinh nghiệm dán decal chuyên nghiệp</p>
    </div>

    <div class="flex justify-center gap-3 mb-12 flex-wrap">
      {categories.map(cat => (
        <button class="filter-btn px-6 py-2 rounded-full border border-slate-200 text-sm font-bold" data-category={cat}>
          {cat}
        </button>
      ))}
    </div>

    <div id="blog-grid" class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-10">
      {allPosts.map(post => (
        <article class="post-card group" data-category={post.data.category}>
          <a href={`/blog/${post.slug}`}>
            <div class="aspect-video rounded-2xl overflow-hidden mb-6 bg-slate-100">
              <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-all" />
            </div>
            <span class="text-primary text-[10px] font-black uppercase tracking-widest">{post.data.category}</span>
            <h2 class="text-xl font-bold text-secondary mt-2 group-hover:text-primary transition-colors">{post.data.title}</h2>
            <p class="text-slate-500 text-sm mt-3 line-clamp-2">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  </main>
</Layout>

<script>
  // Logic Filter giữ nguyên như bản trước...
</script>
