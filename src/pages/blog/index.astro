---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

// Sắp xếp bài viết linh hoạt theo cả hai loại ngày tháng
allPosts.sort((a, b) => {
  const dateA = a.data.date || a.data.pubDate || new Date(0);
  const dateB = b.data.date || b.data.pubDate || new Date(0);
  return dateB.valueOf() - dateA.valueOf();
});

const categories = ["Tất cả", "Kiến thức", "Dự án", "Khuyến mãi", "Mẫu thiết kế"];
---

<Layout title="Blog iDecal | Tin tức">
  <main class="bg-white pt-20 pb-24">
    <div id="blog-grid" class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-10">
      {allPosts.map(post => {
        // Xử lý Category linh hoạt
        const displayCategory = (post.data.categories && post.data.categories[0]) || post.data.category || "Kiến thức";
        
        // GIẢI PHÁP SỬA LỖI UNDEFINED:
        // Ưu tiên lấy slug từ Frontmatter (data.slug), nếu không có mới lấy slug mặc định của file
        const finalSlug = post.data.slug || post.slug;

        return (
          <article class="post-card group" data-category={displayCategory}>
            <a href={`/blog/${finalSlug}`}>
              <div class="aspect-video rounded-2xl overflow-hidden mb-6 bg-slate-100">
                <img src={post.data.image || "/images/default-thumb.jpg"} alt={post.data.title} class="w-full h-full object-cover" />
              </div>
              <span class="text-primary text-[10px] font-black uppercase">{displayCategory}</span>
              <h2 class="text-xl font-bold text-secondary mt-2">{post.data.title}</h2>
              <p class="text-slate-500 text-sm mt-3 line-clamp-2">{post.data.description}</p>
            </a>
          </article>
        );
      })}
    </div>
  </main>
</Layout>
