---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Lấy gallery từ dữ liệu file markdown
const gallery = entry.data.gallery || [];

const allProjects = await getCollection('projects');
const related = allProjects.filter(p => p.data.category === entry.data.category && p.slug !== entry.slug).slice(0, 3);
---

<Layout title={`${entry.data.title} | iDecal`}>
  <main class="bg-white pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-6">
      
      <header class="mb-12">
        <nav class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-6">
          <a href="/" class="hover:text-[#031246]">Trang chủ</a>
          <span>/</span>
          <a href="/du-an" class="hover:text-[#031246]">Dự án</a>
          <span>/</span>
          <span class="text-[#031246] font-bold">{entry.data.category}</span>
        </nav>
        <h1 class="text-[20px] md:text-[24px] font-bold text-[#031246] leading-tight max-w-4xl tracking-tight">
          {entry.data.title}
        </h1>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <div class="lg:col-span-8">
          <div class="rounded-2xl overflow-hidden shadow-lg mb-10 border border-slate-100">
             <img src={entry.data.image} alt={entry.data.title} class="w-full h-auto object-cover" />
          </div>

          <article class="prose prose-slate prose-lg max-w-none mb-16 prose-headings:text-[#031246] prose-a:text-[#00AEEF]">
            <Content />
          </article>

          {gallery.length > 0 && (
            <section class="mb-16">
              <h3 class="text-lg font-bold text-[#031246] mb-8 uppercase tracking-widest border-l-4 border-[#00AEEF] pl-4">Hình ảnh thực tế</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {gallery.map((img, index) => (
                  <div class="overflow-hidden rounded-xl shadow-sm hover:shadow-md transition-all">
                    <img src={img} alt={`Công trình thực tế iDecal ${index + 1}`} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
                  </div>
                ))}
              </div>
            </section>
          )}
        </div>

        <div class="lg:col-span-4">
          <div class="sticky top-32 space-y-8">
            
            <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
              <h3 class="text-[#031246] font-bold uppercase tracking-widest text-[11px] mb-6 pb-4 border-b border-slate-200">Chi tiết hạng mục</h3>
              <div class="space-y-6">
                <div>
                  <p class="text-slate-400 text-[10px] uppercase font-bold mb-1">Khách hàng</p>
                  <p class="text-[#031246] font-bold text-sm">{entry.data.client || "Chưa cập nhật"}</p>
                </div>
                <div>
                  <p class="text-slate-400 text-[10px] uppercase font-bold mb-1">Dịch vụ thi công</p>
                  <p class="text-[#031246] font-bold text-sm">{entry.data.service || "Decal dán kính & Phim cách nhiệt"}</p>
                </div>
                <div>
                  <p class="text-slate-400 text-[10px] uppercase font-bold mb-1">Khu vực thực hiện</p>
                  <p class="text-[#031246] font-bold text-sm">{entry.data.location || "TP. Hồ Chí Minh"}</p>
                </div>
              </div>
            </div>

            <div class="bg-gradient-to-br from-[#031246] to-[#0a1d5a] rounded-2xl p-8 text-white shadow-2xl relative overflow-hidden">
              <div class="relative z-10">
                <h3 class="text-xl font-bold mb-4">Bạn cần giải pháp tương tự?</h3>
                <p class="text-white/70 text-xs mb-8 font-light leading-relaxed">
                   Đội ngũ iDecal hỗ trợ khảo sát mặt bằng và mang mẫu decal đến tận nơi tư vấn hoàn toàn miễn phí.
                </p>
                <div class="space-y-4">
                  <a href="tel:0866077040" class="flex flex-col items-center justify-center bg-[#00AEEF] text-white w-full py-4 rounded-xl transition-all hover:bg-[#008ec4] group">
                    <span class="text-[10px] uppercase tracking-widest opacity-80 font-medium group-hover:opacity-100">Click gọi ngay</span>
                    <span class="font-bold text-base mt-0.5">0866.077.040</span>
                  </a>
                  
                  <a href="https://zalo.me/0866077040" target="_blank" class="flex flex-col items-center justify-center border border-white/20 w-full py-3.5 rounded-xl transition-all hover:bg-white/10 group">
                    <span class="text-[9px] uppercase tracking-widest opacity-60 font-medium group-hover:opacity-100">Tư vấn qua Zalo</span>
                    <span class="font-bold text-xs mt-0.5">Gửi mẫu & Báo giá</span>
                  </a>
                </div>
              </div>
              <div class="absolute bottom-0 right-0 w-32 h-32 bg-[#00AEEF]/10 rounded-full blur-3xl"></div>
            </div>

          </div>
        </div>
      </div>

      {related.length > 0 && (
        <section class="pt-20 mt-20 border-t border-slate-100">
          <div class="flex justify-between items-end mb-10">
            <h3 class="text-xl font-bold text-[#031246]">Công trình cùng danh mục</h3>
            <a href="/du-an" class="text-[11px] font-bold text-slate-400 uppercase tracking-widest hover:text-[#00AEEF]">Xem tất cả dự án →</a>
          </div>
          <div class="grid md:grid-cols-3 gap-8">
            {related.map(p => (
              <a href={`/du-an/${p.slug}`} class="group">
                <div class="aspect-[4/3] rounded-xl overflow-hidden mb-4 shadow-sm">
                  <img src={p.data.image} alt={p.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500" />
                </div>
                <h4 class="text-sm font-bold text-[#031246] group-hover:text-[#00AEEF] transition-colors line-clamp-1">{p.data.title}</h4>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>
</Layout>
