---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ["Tất cả", "Văn phòng", "Căn hộ", "Showroom", "Sự kiện"];
---

<Layout title="Dự án tiêu biểu | iDecal">
  <main class="bg-white pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h1 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight bg-gradient-to-r from-[#031246] via-[#031246] to-[#00AEEF] bg-clip-text text-transparent">
          Công trình đã thực hiện
        </h1>
        <p class="text-slate-400 text-[10px] uppercase tracking-[0.4em] font-medium">Kỹ thuật - Thẩm mỹ - Tận tâm</p>
      </div>

      <div class="flex flex-wrap justify-center gap-3 mb-20">
        {categories.map(cat => (
          <button 
            class="project-filter px-7 py-2 rounded-full border border-slate-100 text-slate-400 font-bold text-[11px] uppercase tracking-[0.1em] transition-all hover:text-[#031246] hover:bg-slate-50 active:scale-95" 
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <div id="project-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-14">
        {allProjects.map(project => (
          <div class="project-card group flex flex-col" data-category={project.data.category}>
            <div class="overflow-hidden rounded-xl aspect-[4/3] shadow-sm mb-5 relative">
              <img 
                src={project.data.image} 
                alt={project.data.title} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" 
              />
              
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm text-[#031246] px-3 py-1 rounded-lg z-10 shadow-sm">
                <span class="font-bold text-[9px] uppercase tracking-[0.1em]">
                  {project.data.category}
                </span>
              </div>
            </div>
            
            <div class="flex flex-col px-1">
              <h2 class="text-[#031246] text-base font-bold mb-2 tracking-tight group-hover:text-[#00AEEF] transition-colors line-clamp-1">
                {project.data.title}
              </h2>
              
              <p class="text-slate-400 text-[13px] mb-4 line-clamp-2 font-light leading-relaxed">
                {project.data.description}
              </p>
              
              <a href={`/du-an/${project.slug}`} class="inline-flex items-center text-[#031246] font-bold text-[10px] uppercase tracking-[0.2em] group/link w-fit opacity-80 hover:opacity-100">
                Khám phá
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-2 transform group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

      <section class="mt-32 bg-gradient-to-br from-[#031246] to-[#0a1d5a] rounded-[2rem] p-10 md:p-20 text-center relative overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-[#00AEEF]/10 rounded-full blur-3xl -mr-48 -mt-48"></div>
        <div class="relative z-10">
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-6 tracking-tight">Cần tư vấn giải pháp dán kính chuyên nghiệp?</h2>
          <div class="flex flex-wrap justify-center gap-5">
            <a href="tel:0866077040" class="bg-[#00AEEF] text-white px-10 py-4 rounded-full font-bold uppercase tracking-[0.15em] text-[11px] hover:bg-[#008ec4] transition-all shadow-lg shadow-[#00AEEF]/20">
              Liên hệ Hotline
            </a>
            <a href="/lien-he" class="bg-white/5 backdrop-blur-md border border-white/10 text-white px-10 py-4 rounded-full font-bold uppercase tracking-[0.15em] text-[11px] hover:bg-white/10 transition-all">
              Nhận báo giá
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<script>
  const filters = document.querySelectorAll('.project-filter');
  const cards = document.querySelectorAll('.project-card');

  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');
      
      filters.forEach(b => {
        b.classList.remove('bg-[#031246]', 'text-white', 'border-[#031246]');
        b.classList.add('border-slate-100', 'text-slate-400');
      });
      
      btn.classList.add('bg-[#031246]', 'text-white', 'border-[#031246]');
      btn.classList.remove('border-slate-100', 'text-slate-400');

      cards.forEach(card => {
        const cardCat = card.getAttribute('data-category');
        if (cat === "Tất cả" || cardCat === cat) {
          (card as HTMLElement).style.display = 'flex';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  (document.querySelector('[data-category="Tất cả"]') as HTMLElement).click();
</script>
