---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string; // Thêm mô tả để tốt cho SEO
}

const { title, description = "Dịch vụ decal dán kính cách nhiệt & trang trí chuyên nghiệp" } = Astro.props;
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body class="bg-background font-body text-secondary">
		<Header />
		
		<main>
			<slot /> 
		</main>

		<Footer />
	</body>
</html>

<style is:global>
	/* Định nghĩa Font cho tiêu đề trên toàn bộ trang */
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Be Vietnam Pro', sans-serif;
	}
	
	/* Đảm bảo trang luôn đủ chiều cao để Footer nằm ở dưới cùng */
	body {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}
	main {
		flex: 1;
	}
</style>
