---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body class="bg-background font-body text-secondary">
		<slot />
	</body>
</html>

<style is:global>
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Be Vietnam Pro', sans-serif;
	}
</style>
