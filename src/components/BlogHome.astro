---
import { getCollection } from 'astro:content';

// Lấy 3 bài viết mới nhất
const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-primary font-bold uppercase tracking-widest text-sm mb-3">Tin tức & Chia sẻ</h2>
        <h3 class="text-3xl md:text-4xl font-bold text-secondary">Kiến thức decal & Dự án mới</h3>
        <p class="text-slate-500 text-sm lowercase mt-2">cập nhật những xu hướng trang trí và kỹ thuật thi công mới nhất</p>
      </div>
      
      <a href="/blog" class="group flex items-center gap-2 text-secondary font-bold hover:text-primary transition-colors whitespace-nowrap">
        XEM TẤT CẢ BLOG
        <span class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </a>
    </div>

    <div class="flex overflow-x-auto pb-8 md:pb-0 md:grid md:grid-cols-3 gap-8 snap-x snap-mandatory scrollbar-hide">
      {latestPosts.map((post) => (
        <article class="min-w-[85%] md:min-w-0 snap-center group cursor-pointer">
          <a href={`/blog/${post.slug}`}>
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-6 border border-slate-50 shadow-sm">
              <img 
                src={post.data.image} 
                alt={post.data.title} 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
              />
              <div class="absolute top-4 left-4">
                <span class="bg-white/90 backdrop-blur px-3 py-1 rounded-lg text-[10px] font-black uppercase text-primary tracking-tighter">
                  {post.data.category}
                </span>
              </div>
            </div>
            
            <div class="space-y-3 px-2">
              <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest">
                {post.data.pubDate.toLocaleDateString('vi-VN')}
              </p>
              <h4 class="text-xl font-bold text-secondary group-hover:text-primary transition-colors leading-tight">
                {post.data.title}
              </h4>
              <p class="text-slate-500 text-sm line-clamp-2 leading-relaxed">
                {post.data.description}
              </p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Ẩn thanh cuộn nhưng vẫn cho phép scroll trên mobile */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
