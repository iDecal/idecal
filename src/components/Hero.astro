---
interface Props {
  badge: string;
  title: string;
  highlight: string;
  description: string;
  image: string;
}
const { badge, title, highlight, description, image } = Astro.props;
---
<section class="relative bg-white pt-20 pb-16 lg:pt-32 lg:pb-24">
  <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
    <div>
      <span class="inline-block bg-primary/10 text-primary px-4 py-1 rounded-full text-xs font-bold mb-6">{badge}</span>
      <h1 class="text-4xl md:text-6xl font-bold text-secondary leading-tight mb-6">
        {title} <span class="text-primary">{highlight}</span>
      </h1>
      <p class="text-lg text-slate-600 mb-10 leading-relaxed">{description}</p>
      <div class="flex flex-wrap gap-4">
        <a href="#contact" class="bg-primary hover:bg-primary-dark text-white px-8 py-4 rounded-brand font-bold transition-all shadow-lg shadow-primary/20">BÁO GIÁ NGAY</a>
        <a href="#portfolio" class="border-2 border-secondary text-secondary hover:bg-secondary hover:text-white px-8 py-4 rounded-brand font-bold transition-all">XEM CÔNG TRÌNH</a>
      </div>
    </div>
    <div class="relative rounded-[2rem] overflow-hidden shadow-2xl border-[12px] border-slate-50">
      <img src={image} alt="iDecal Hero" class="w-full h-auto object-cover" />
    </div>
  </div>
</section>
