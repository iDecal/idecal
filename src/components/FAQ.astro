<div class="grid lg:grid-cols-2 gap-x-12 gap-y-6 items-start">
      {faqs.map((faq) => (
        <div class="faq-item transition-all duration-300">
          <details class="faq-details group lg:pointer-events-none cursor-pointer lg:cursor-default" open>
            
            <summary class="flex items-center justify-between list-none py-4 font-bold text-secondary group-open:text-primary transition-colors leading-tight px-2">
              <span class="flex gap-4 items-start">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/10 text-primary text-[10px] flex items-center justify-center font-black">Q</span>
                <span class="text-[15px] md:text-base text-secondary">{faq.q}</span>
              </span>
              <span class="lg:hidden transform group-open:rotate-180 transition-transform duration-300 text-slate-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            
            <div class="flex gap-4 p-5 bg-slate-50/80 rounded-2xl animate-fadeIn items-start border border-slate-100/50">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-white text-secondary/40 text-[10px] flex items-center justify-center font-black shadow-sm">A</span>
              <p class="text-text-muted text-sm leading-relaxed !mb-0">{faq.a}</p>
            </div>

          </details>
        </div>
      ))}
    </div>
