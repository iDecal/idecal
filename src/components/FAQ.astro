---
const faqs = [
  { 
    q: "Decal mờ 3D có che hoàn toàn tầm nhìn không?", 
    a: "Sản phẩm này có độ mờ từ 20-30%, giúp tạo không gian riêng tư nhưng vẫn đảm bảo ánh sáng tự nhiên đi qua, tạo cảm giác thông thoáng cho văn phòng." 
  },
  { 
    q: "Phim cách nhiệt tại iDecal bảo hành bao lâu?", 
    a: "Tất cả các dòng phim cách nhiệt cao cấp được iDecal thi công đều có chế độ bảo hành từ 5-10 năm về các thông số cách nhiệt và độ bền màu." 
  },
  { 
    q: "Tôi có thể tự dán decal tại nhà không?", 
    a: "Bạn hoàn toàn có thể tự dán. Tuy nhiên, để đảm bảo bề mặt phẳng mịn, không bị bọt khí và thẩm mỹ cao nhất, đội ngũ kỹ thuật của iDecal luôn sẵn sàng hỗ trợ lắp đặt chuyên nghiệp." 
  },
  { 
    q: "iDecal có nhận thi công tại các tỉnh ngoài TP.HCM không?", 
    a: "Hiện tại iDecal tập trung phục vụ chính tại TP.HCM, Bình Dương và Quy Nhơn. Với các dự án lớn tại tỉnh lân cận, chúng tôi vẫn hỗ trợ khảo sát và thi công tận nơi." 
  },
  { 
    q: "Chất liệu phim dán nội thất có bền không?", 
    a: "Các dòng phim Octki, GYMak chúng tôi sử dụng có khả năng chống trầy xước, chống ẩm mốc và độ bền lên đến 7-10 năm trong điều kiện nội thất." 
  },
  { 
    q: "Thời gian thi công một công trình thường mất bao lâu?", 
    a: "Tùy vào khối lượng, nhưng đa số các công trình văn phòng hoặc căn hộ thông thường iDecal sẽ hoàn thiện nhanh chóng ngay trong ngày." 
  }
];
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-primary font-bold uppercase tracking-widest text-sm mb-3">Giải đáp thắc mắc</h2>
      <h3 class="text-3xl md:text-4xl font-bold text-secondary mb-2">Câu hỏi thường gặp</h3>
      <p class="text-slate-500 text-sm lowercase">tất cả các giải đáp về dịch vụ và bảo hành tại idecal</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-x-16 gap-y-2 items-start">
      {faqs.map((faq) => (
        <div class="border-b border-slate-100 pb-2">
          <details class="faq-details group lg:pointer-events-none cursor-pointer lg:cursor-default">
            
            <summary class="flex items-center justify-between list-none py-4 text-secondary font-bold text-xl group-open:text-primary transition-colors leading-tight">
              <span class="flex gap-3">
                <span class="text-primary opacity-50">Q.</span>
                {faq.q}
              </span>
              <span class="lg:hidden transform group-open:rotate-180 transition-transform duration-300 text-slate-300 group-open:text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            
            <div class="flex gap-3 text-slate-600 leading-relaxed text-base pb-4 animate-fadeIn">
              <span class="text-primary font-bold opacity-50">A.</span>
              <p>{faq.a}</p>
            </div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.4s ease-out;
  }
  
  summary::-webkit-details-marker {
    display: none;
  }

  @media (min-width: 1024px) {
    .faq-details {
      display: block !important;
    }
    .faq-details[open] summary {
      cursor: default;
    }
    .faq-details div {
      display: flex !important;
    }
  }

  @media (max-width: 1023px) {
    .faq-details div {
      display: none;
    }
    .faq-details[open] div {
      display: flex;
    }
  }
</style>

<script>
  function handleDesktopFAQ() {
    if (window.innerWidth >= 1024) {
      document.querySelectorAll('.faq-details').forEach(el => {
        el.setAttribute('open', '');
      });
    }
  }
  handleDesktopFAQ();
  window.addEventListener('resize', handleDesktopFAQ);
</script>
