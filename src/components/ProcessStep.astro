---
interface Props {
  number: string;
  title: string;
  description: string;
}
const { number, title, description } = Astro.props;
---
<div class="p-10 bg-surface-100 rounded-brand shadow-soft border border-surface-300 relative overflow-hidden group">
  <div class="text-surface-300 font-black text-8xl absolute -top-4 -right-2 z-0">{number}</div>
  <div class="relative z-10">
    <h3 class="text-title-sm font-heading font-black mb-4 uppercase group-hover:text-primary transition-colors">
      {title}
    </h3>
    <p class="text-body-sm font-body leading-relaxed opacity-70">
      {description}
    </p>
  </div>
</div>
