---
const partners = [
  { name: "3M", logo: "/images/logo-hang/LOGO-3M.png" },
  { name: "Llumar", logo: "/images/logo-hang/LOGO-Llumar.png" },
  { name: "Avery Denision", logo: "/images/logo-hang/LOGO - Decal Avery.png" },
  { name: "Phim cách nhiệt Rainier", logo: "/images/logo-hang/logo-rainier.webp" },
];
---
<section class="py-12 border-y border-slate-100 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <p class="text-center text-slate-400 text-sm font-bold uppercase tracking-widest mb-8">Đối tác tin cậy</p>
    <div class="flex flex-wrap justify-center items-center gap-12 opacity-60 grayscale hover:grayscale-0 transition-all">
       {partners.map(p => <img src={p.logo} alt={p.name} class="h-8 md:h-12 w-auto" />)}
    </div>
  </div>
</section>
