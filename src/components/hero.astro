---
interface Props {
  badge: string;
  title: string;
  highlight: string;
  description: string;
  image: string;
  stats: string;
}
const { badge, title, highlight, description, image, stats } = Astro.props;
---
<section class="relative bg-surface-100 text-secondary py-20 lg:py-32 overflow-hidden border-b border-surface-300">
  <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center relative z-10">
    <div>
      <span class="inline-block bg-primary/10 px-4 py-1.5 rounded-full text-xs font-bold mb-6 uppercase tracking-wider">
        {badge}
      </span>
      <h1 class="text-title-xl font-heading font-black leading-tight mb-6 uppercase tracking-tighter">
        {title} <span class="text-primary italic underline decoration-primary decoration-2 underline-offset-4">{highlight}</span>
      </h1>
      <p class="text-body font-body mb-8 leading-relaxed max-w-xl opacity-80">
        {description}
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 font-bold">
        <slot name="features" />
      </div>
    </div>
    <div class="relative">
      <div class="absolute -inset-4 bg-primary/5 blur-3xl rounded-full"></div>
      <img src={image} alt={title} class="rounded-3xl shadow-soft relative z-10 border-8 border-surface-100" />
      <div class="absolute -bottom-6 -left-6 bg-surface-100 p-6 rounded-2xl shadow-soft z-20 hidden md:block">
        <p class="text-title-lg font-black">{stats}</p>
        <p class="text-xs opacity-60 uppercase font-bold tracking-tighter">Khách hàng hài lòng</p>
      </div>
    </div>
  </div>
</section>
