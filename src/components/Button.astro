---
// src/components/Button.astro
const { title, href, type = "primary" } = Astro.props;

const styles = {
  primary: "bg-primary text-secondary",
  secondary: "bg-secondary text-white",
  accent: "bg-accent text-secondary"
};
---

<a href={href} class={`${styles[type]} font-bold py-3 px-8 rounded-lg inline-block hover:scale-105 transition-transform`}>
  {title}
</a>
