<section class="py-20 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
    
    <div class="relative order-2 lg:order-1">
      <div class="absolute -bottom-6 -left-6 w-48 h-48 bg-primary/5 rounded-full -z-10 animate-pulse"></div>
      <div class="rounded-[3rem] rounded-tr-[8rem] overflow-hidden shadow-xl border-[8px] border-slate-50">
        <img 
          src="/images/about-idecal.webp" 
          alt="Đội ngũ iDecal" 
          class="w-full h-[450px] object-cover hover:scale-105 transition-transform duration-700" 
        />
      </div>
    </div>

    <div class="order-1 lg:order-2">
      <h2 class="text-primary font-bold text-[10px] uppercase tracking-[0.2em] mb-2">Tại sao chọn iDecal</h2>
      <h3 class="text-2xl md:text-3xl font-bold text-secondary mb-4 leading-tight">
        Giải pháp Decal dán kính trang trí & <br/> <span class="text-primary italic">chống nóng toàn diện</span>
      </h3>
      
      <p class="text-slate-500 mb-6 leading-relaxed text-sm">
        iDecal mang đến giải pháp trang trí – chống nắng – tạo không gian riêng tư với mẫu mã đa dạng, phù hợp cho nhà ở, văn phòng và công trình dự án.
      </p>

      <div class="grid gap-y-5">
        {[
          {
            title: "Chất lượng đảm bảo",
            desc: "Sử dụng 100% Decal chính hãng: Octki, GYMak, Infeel...",
