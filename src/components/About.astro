            desc: "Báo giá minh bạch, tối ưu ngân sách.",
            icon: "M12 6v12m-3-2.818.51.257A6.03 6.03 0 0 0 12 15a6.03 6.03 0 0 0 2.483-.539l.51-.257m-6.205-1.134L8.91 12.1a6.03 6.03 0 0 0 2.483-.539L12 11.304l.607.304a6.03 6.03 0 0 0 2.483.54l.397.052m-6.397-1.136.06-.012A6.03 6.03 0 0 0 11.607 9.55l.393-.197m0 0 .393.197a6.03 6.03 0 0 0 2.483.539l.06.012M9 18h6m-7.5-3.375a1.125 1.125 0 0 1 1.125-1.125h11.25c.621 0 1.125.504 1.125 1.125v3.375c0 .621-.504 1.125-1.125 1.125H3.375a1.125 1.125 0 0 1-1.125-1.125v-3.375Z"
