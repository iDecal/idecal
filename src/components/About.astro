<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
    
    <div class="relative order-2 lg:order-1">
      <div class="absolute -bottom-10 -left-10 w-64 h-64 bg-primary/5 rounded-full -z-10 animate-pulse"></div>
      <div class="rounded-[4rem] rounded-tr-[10rem] overflow-hidden shadow-2xl border-[12px] border-slate-50">
        <img 
          src="/images/about-idecal.webp" 
          alt="Đội ngũ iDecal" 
          class="w-full h-[500px] object-cover hover:scale-105 transition-transform duration-700" 
        />
      </div>
    </div>

    <div class="order-1 lg:order-2">
      <h2 class="text-primary font-bold text-sm uppercase tracking-widest mb-4">Tại sao chọn iDecal</h2>
      <h3 class="text-3xl md:text-4xl lg:text-5xl font-bold text-secondary mb-8 leading-tight">
        Giải pháp Decal dán kính trang trí & <br/> <span class="text-primary italic">chống nóng toàn diện</span>
      </h3>
      
      <p class="text-slate-600 mb-10 leading-relaxed text-lg">
        iDecal mang đến giải pháp trang trí – chống nắng – tạo không gian riêng tư với mẫu mã đa dạng, phù hợp cho nhà ở, văn phòng, showroom, cửa hàng và công trình dự án.
      </p>

      <div class="grid gap-y-8">
        {[
          {
            title: "Chất lượng đảm bảo",
            desc: "Sử dụng 100% Decal chính hãng từ các thương hiệu lớn: Octki, GYMak, Infeel...",
