---
const services = [
  { 
    title: "Phim Cách Nhiệt", 
    description: "Cách nhiệt 80%, ngăn 99% UV cho nhà kính.", 
    image: "/images/pcn.webp", 
    link: "/phim-cach-nhiet" 
  },
  { 
    title: "Decal Mờ 3D", 
    description: "Vân nổi sống động, tăng tính riêng tư.", 
    image: "/images/mo3d.webp", 
    link: "/decal-mo-3d" 
  },
  { 
    title: "Decal Cắt Chữ", 
    description: "Cắt CNC logo, sticker theo yêu cầu.", 
    image: "/images/cat.webp", 
    link: "/decal-cat-chu" 
  },
  { 
    title: "Phim Nội Thất", 
    description: "Làm mới nội thất với vân gỗ, đá.", 
    image: "/images/film.webp", 
    link: "/film-noithat" 
  },
  { 
    title: "Decal Quảng Cáo", 
    description: "In PP, Vinyl sắc nét.", 
    image: "/images/adv.webp", 
    link: "/decal-quang-cao" 
  },
  { 
    title: "Decal Văn Phòng", 
    description: "Thi công trọn gói văn phòng.", 
    image: "/images/vp.webp", 
    link: "/decal-van-phong" 
  }
];
---

<section class="services">
  <div class="container">

    <!-- HEADER -->
    <div class="section-header">
      <p class="section-subtitle">Dịch vụ trọng tâm</p>
      <h2 class="section-title">Giải pháp dán kính & Nội thất</h2>
    </div>

    <!-- GRID -->
    <div class="services-grid">
      {services.map((item) => (
        <a href={item.link} class="service-card">

          <!-- IMAGE -->
          <div class="service-card-image">
            <img 
              src={item.image} 
              alt={item.title} 
              loading="lazy"
              onerror="this.style.display='none'"
            />
          </div>

          <!-- CONTENT -->
          <div class="service-card-body">
            <h3 class="service-card-title">{item.title}</h3>
            <p class="service-card-desc">{item.description}</p>

            <span class="service-card-link">
              Chi tiết sản phẩm →
            </span>
          </div>

        </a>
      ))}
    </div>

  </div>
</section>
