---
const services = [
  { 
    title: "Phim Cách Nhiệt", 
    description: "Cách nhiệt 80%, ngăn 99% UV cho nhà kính.", 
    image: "/images/phim-cach-nhiet/Thi-cong-dan-phim-cach-nhiet-van-phong-cong-ty.webp", 
    link: "/Dich-vu/phim-cach-nhiet" 
  },
  { 
    title: "Decal Mờ 3D", 
    description: "Vân nổi sống động, tăng tính riêng tư.", 
    image: "/images/mo3d.webp", 
    link: "/decal-mo-3d" 
  },
  { 
    title: "Decal Cắt Chữ", 
    description: "Cắt CNC logo, sticker theo yêu cầu.", 
    image: "/images/Banner/decal-cat-chu-trang-tri-quang-cao.jpg", 
    link: "Dich-vu/cat-decal" 
  },
  { 
    title: "Phim Nội Thất", 
    description: "Làm mới nội thất với vân gỗ, đá.", 
    image: "/images/film-noi-that/Phim-dan-noi-that-cao-cap.jpg", 
    link: "Dich-vu/film-noithat" 
  },
  { 
    title: "Decal Quảng Cáo", 
    description: "In PP, Vinyl sắc nét.", 
    image: "/images/cong-trinh/Trang-tri-kinh-phong-kham-FDcare.png", 
    link: "/Dich-vu/decal-quang-cao" 
  },
  { 
    title: "Decal Văn Phòng", 
    description: "Thi công trọn gói văn phòng.", 
    image: "/images/vp.webp", 
    link: "/Dich-vu/decal-dan-kinh-van-phong" 
  }
];
---

<section class="py-20 bg-slate-50/50">
  <div class="container">

    <div class="text-center mb-16">
      <p class="text-primary font-bold uppercase tracking-[0.2em] text-[10px] mb-3">
        Dịch vụ trọng tâm
      </p>
      <h2 class="text-h2">Giải pháp dán kính & Nội thất</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((item) => (
        <a href={item.link} class="group bg-white rounded-brand border border-border shadow-card hover:shadow-brand transition-all duration-500 overflow-hidden flex flex-col">

          <div class="aspect-[16/10] overflow-hidden bg-slate-100">
            <img 
              src={item.image} 
              alt={item.title} 
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              onerror="this.src='https://placehold.co/600x400?text=iDecal'"
            />
          </div>

          <div class="p-6 flex flex-col flex-grow">
            <h4 class="text-h4 mb-3 group-hover:text-primary transition-colors">
              {item.title}
            </h4>
            
            <p class="text-text-muted text-sm leading-relaxed mb-6 flex-grow">
              {item.description}
            </p>

            <div class="mt-auto">
              <span class="btn-idecal-bold">
                Chi tiết sản phẩm
                <svg class="w-3 h-3 transition-transform group-hover:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </div>

        </a>
      ))}
    </div>

  </div>
</section>
