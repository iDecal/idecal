---
import { getCollection } from 'astro:content';

// Tự động lấy 3 dự án mới nhất từ thư mục src/content/projects
const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section id="portfolio" class="py-24 bg-slate-50">
  <div class="container">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
      <div>
        <h2 class="text-h2 !mb-2">Dự án tiêu biểu</h2>
        <p class="text-text-muted text-sm font-medium italic">
          Khẳng định chất lượng qua từng công trình thực tế
        </p>
      </div>
      
      <a href="/du-an" class="btn-idecal-bold mb-1">
        Xem tất cả dự án
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {projects.map(p => (
        <a href={`/du-an/${p.slug}`} class="group flex flex-col h-full">
          <div class="relative overflow-hidden rounded-brand aspect-[4/3] mb-5 shadow-card group-hover:shadow-brand transition-all duration-500">
            <img 
              src={p.data.image} 
              alt={p.data.title} 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
            />
            <div class="absolute top-4 right-4">
               <span class="bg-white/90 backdrop-blur-sm text-secondary text-[10px] font-bold px-3 py-1 rounded-full shadow-sm">
                 {p.data.category}
               </span>
            </div>
          </div>

          <div class="px-2 flex flex-col flex-grow">
            <h4 class="text-h4 group-hover:text-primary transition-colors mb-3">
              {p.data.title}
            </h4>
            
            <div class="mt-auto flex flex-wrap gap-4 items-center">
              <div class="flex items-center gap-1.5 text-text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="text-xs">TP. Hồ Chí Minh</span>
              </div>
              
              <div class="flex items-center gap-1.5 text-text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                <span class="text-xs italic">Thi công & Thiết kế</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
