---
import { getCollection } from 'astro:content';

// Tự động lấy 3 dự án mới nhất từ thư mục src/content/projects
const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section id="portfolio" class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-secondary mb-2">Dự án tiêu biểu</h2>
        <p class="text-slate-500 text-xs uppercase tracking-[0.2em]">Khẳng định chất lượng qua từng công trình thực tế</p>
      </div>
      <a href="/du-an" class="text-primary font-black text-xs uppercase tracking-widest hover:text-secondary transition-colors flex items-center gap-2 group">
        Xem tất cả dự án
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {projects.map(p => (
        <a href={`/du-an/${p.slug}`} class="group">
          <div class="relative overflow-hidden rounded-[2rem] aspect-[4/3] mb-5 shadow-sm">
            <img 
              src={p.data.image} 
              alt={p.data.title} 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
            />
            <div class="absolute top-4 right-4">
               <span class="bg-white/90 backdrop-blur-sm text-secondary text-[10px] font-black px-3 py-1 rounded-full shadow-sm">
                 {p.data.category}
               </span>
            </div>
          </div>

          <div class="px-2">
            <h4 class="text-lg font-bold text-secondary group-hover:text-primary transition-colors mb-3 leading-tight">
              {p.data.title}
            </h4>
            
            <div class="flex flex-wrap gap-4 items-center">
              <div class="flex items-center gap-1.5 text-slate-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="text-[11px] font-medium uppercase tracking-tight">TP. Hồ Chí Minh</span>
              </div>
              
              <div class="flex items-center gap-1.5 text-slate-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                <span class="text-[11px] font-medium uppercase tracking-tight italic">Thi công & Thiết kế</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
