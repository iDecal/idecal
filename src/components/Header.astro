---
// Navbar.astro - iDecal Navigation Component
const navLinks = [
  { name: "Trang chủ", href: "/" },
  { name: "Giới thiệu", href: "/gioi-thieu" },
  { 
    name: "Dịch vụ", 
    href: "#",
    dropdown: [
      { name: "Thiết kế - In ấn - Thi công Decal", href: "/dich-vu-tron-goi", highlight: true }, 
      { name: "Phim Cách Nhiệt", href: "/phim-cach-nhiet" },
      { name: "Decal 3D Vân Sóng", href: "/decal-mo-3d-van-song" },
      { name: "Decal Cắt Chữ", href: "/cat-decal" },
      { name: "Decal Quảng Cáo", href: "/decal-quang-cao" },
      { name: "Film Dán Nội Thất", href: "/film-noi-that" },
      { name: "Decal Dán Kính Văn Phòng", href: "/decal-dan-kinh-van-phong" },
    ]
  },
  { name: "Công trình thực tế", href: "/du-an" },
  { name: "Blog Kiến Thức", href: "/blog" },
  { name: "Liên hệ", href: "/lien-he" },
];
---

<nav class="fixed w-full z-50 bg-white/95 backdrop-blur-md border-b border-slate-100 shadow-sm">
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center h-20">
      
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-slate-950 font-black text-xl group-hover:rotate-12 transition-transform">i</div>
          <span class="text-2xl font-black text-slate-900 tracking-tighter">Decal</span>
        </a>
      </div>

      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          <div class="relative group py-8">
            <a 
              href={link.href} 
              class="text-[13px] font-bold text-slate-600 hover:text-primary uppercase tracking-widest transition-colors flex items-center gap-1"
            >
              {link.name}
              {link.dropdown && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-50 group-hover:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>

            {link.dropdown && (
              <div class="absolute top-[90%] left-0 w-72 bg-white shadow-2xl rounded-2xl border border-slate-100 p-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all transform translate-y-2 group-hover:translate-y-0">
                <div class="grid gap-1">
                  {link.dropdown.map((sub) => (
                    <a 
                      href={sub.href} 
                      class={`block px-4 py-3 text-sm rounded-xl transition-all font-medium ${sub.highlight ? 'bg-primary text-slate-950 font-bold mb-2' : 'text-slate-600 hover:bg-slate-50 hover:text-primary'}`}
                    >
                      {sub.name}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="hidden lg:flex items-center gap-4">
        <a href="tel:090xxxxxxx" class="flex flex-col items-end mr-2 group">
          <span class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">Hotline 24/7</span>
          <span class="text-sm font-black text-secondary tracking-wide group-hover:text-primary transition-colors font-mono">090x.xxx.xxx</span>
        </a>
        <a href="/lien-he" class="bg-slate-950 text-white px-8 py-3.5 rounded-xl font-bold text-xs uppercase tracking-[0.15em] hover:bg-primary hover:text-slate-950 transition-all shadow-xl shadow-slate-900/10 active:scale-95">
          Tư vấn miễn phí
        </a>
      </div>

      <button id="menu-toggle" class="lg:hidden p-2 text-slate-900" aria-label="Open Menu">
        <div class="w-6 h-5 flex flex-col justify-between">
          <span class="w-full h-0.5 bg-current rounded-full"></span>
          <span class="w-3/4 h-0.5 bg-current rounded-full ml-auto"></span>
          <span class="w-full h-0.5 bg-current rounded-full"></span>
        </div>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-white z-[60] transform translate-x-full transition-transform duration-500 lg:hidden flex flex-col">
    <div class="p-6 flex justify-between items-center border-b border-slate-100">
      <span class="text-2xl font-black text-slate-900 font-mono">i<span class="text-primary font-sans">Decal</span></span>
      <button id="menu-close" class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center text-slate-900 text-3xl hover:bg-slate-200">&times;</button>
    </div>
    
    <div class="flex-1 overflow-y-auto p-8 space-y-10">
      {navLinks.map((link) => (
        <div class="space-y-5">
          <a href={link.href} class="text-3xl font-black text-slate-900 hover:text-primary transition-colors inline-block tracking-tighter">{link.name}</a>
          {link.dropdown && (
            <div class="grid gap-5 ml-4 border-l-2 border-slate-100 pl-6">
              {link.dropdown.map((sub) => (
                <a href={sub.href} class={`text-lg font-bold transition-colors ${sub.highlight ? 'text-primary' : 'text-slate-400 hover:text-slate-600'}`}>
                  {sub.name}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="p-6 border-t border-slate-100 space-y-4 bg-slate-50">
      <a href="tel:090xxxxxxx" class="w-full block bg-primary text-slate-950 text-center py-5 rounded-2xl font-black uppercase tracking-widest text-lg shadow-lg shadow-primary/20 active:scale-[0.98] transition-transform">
        Tư vấn miễn phí
      </a>
      <p class="text-center text-[11px] text-slate-400 font-bold uppercase tracking-[0.2em]">Khảo sát & Mang mẫu tận nhà</p>
    </div>
  </div>
</nav>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';
  });

  menuClose?.addEventListener('click', () => {
    mobileMenu?.classList.add('translate-x-full');
    document.body.style.overflow = ''; 
  });

  const links = mobileMenu?.querySelectorAll('a');
  links?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('translate-x-full');
      document.body.style.overflow = '';
    });
  });
</script>
