---
// Header.astro
// Hướng đến các từ khóa: thi công decal, phim cách nhiệt, decal mờ văn phòng
---

<header class="fixed w-full z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <div class="flex-shrink-0">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl font-black text-primary-900 tracking-tighter">iDECAL</span>
        <span class="w-2 h-2 bg-accent-500 rounded-full"></span>
      </a>
    </div>

    <nav class="hidden lg:flex items-center gap-8">
      <a href="/" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">TRANG CHỦ</a>
      <a href="/gioi-thieu" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">GIỚI THIỆU</a>
      
      <div class="relative group">
        <button class="flex items-center gap-1 text-sm font-bold text-gray-700 group-hover:text-primary-600 transition-colors uppercase">
          Dịch vụ
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor font-bold">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        
        <div class="absolute top-full -left-4 w-64 bg-white shadow-xl border border-gray-50 rounded-2xl py-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0">
          <a href="/dich-vu/decal-dan-kinh-van-phong" class="block px-6 py-2 text-sm font-medium text-gray-600 hover:bg-primary-50 hover:text-primary-600">Decal Dán Kính Văn Phòng</a>
          <a href="/dich-vu/phim-cach-nhiet" class="block px-6 py-2 text-sm font-medium text-gray-600 hover:bg-primary-50 hover:text-primary-600">Phim Cách Nhiệt Nhà Kính</a>
          <a href="/dich-vu/decal-mo-3d" class="block px-6 py-2 text-sm font-medium text-gray-600 hover:bg-primary-50 hover:text-primary-600">Decal Mờ 3D Cao Cấp</a>
          <a href="/dich-vu/cat-chu-logo" class="block px-6 py-2 text-sm font-medium text-gray-600 hover:bg-primary-50 hover:text-primary-600">Cắt Chữ & Logo Công Ty</a>
        </div>
      </div>

      <a href="/du-an" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">DỰ ÁN ĐÃ LÀM</a>
      <a href="/lien-he" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">LIÊN HỆ</a>
    </nav>

    <div class="flex items-center gap-4">
      <a href="tel:086677040" class="hidden sm:flex items-center gap-2 bg-primary-50 text-primary-600 px-4 py-2 rounded-xl font-black text-sm border border-primary-100 hover:bg-primary-100 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor font-bold">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        0866-77040
      </a>
      
      <button class="lg:hidden p-2 text-primary-900">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="h-20"></div>
