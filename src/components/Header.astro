---
// Header.astro
// Tối ưu danh sách dịch vụ đầy đủ dựa trên silo content của iDecal
const services = [
  { name: "Decal Dán Kính Văn Phòng", href: "/dich-vu/decal-dan-kinh-van-phong" },
  { name: "Phim Cách Nhiệt Nhà Kính", href: "/dich-vu/phim-cach-nhiet" },
  { name: "Decal Mờ 3D Cao Cấp", href: "/dich-vu/decal-mo-3d" },
  { name: "Cắt Chữ & Logo Công Ty", href: "/dich-vu/decal-cat-chu" },
  { name: "Phim Dán Nội Thất", href: "/dich-vu/phim-dan-noi-that" },
  { name: "Decal Quảng Cáo (PP/Vinyl)", href: "/dich-vu/decal-quang-cao" }
];
---

<header class="fixed w-full z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-neutral-100">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <div class="flex-shrink-0">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl font-black text-primary-900 tracking-tighter">iDECAL</span>
        <span class="w-2 h-2 bg-accent-500 rounded-full"></span>
      </a>
    </div>

    <nav class="hidden lg:flex items-center gap-8">
      <a href="/" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">TRANG CHỦ</a>
      
      <div class="relative group">
        <button class="flex items-center gap-1 text-sm font-bold text-gray-700 group-hover:text-primary-600 transition-colors uppercase">
          Dịch vụ
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-full -left-4 w-64 bg-white shadow-xl border border-neutral-100 rounded-2xl py-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2">
          {services.map(service => (
            <a href={service.href} class="block px-6 py-2.5 text-sm font-medium text-gray-600 hover:bg-neutral-50 hover:text-primary-600">{service.name}</a>
          ))}
        </div>
      </div>

      <a href="/du-an" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">DỰ ÁN</a>
      <a href="/lien-he" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">LIÊN HỆ</a>
    </nav>

    <div class="flex items-center gap-4">
      <a href="tel:086677040" class="hidden sm:block text-primary-600 font-black text-lg">0866-77040</a>
      <button id="menu-btn" class="lg:hidden p-2 text-primary-900 focus:outline-none">
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" /></svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden fixed inset-0 top-20 bg-white z-40 overflow-y-auto">
    <div class="p-6 flex flex-col gap-6">
      <a href="/" class="text-xl font-black text-primary-900 uppercase">Trang chủ</a>
      
      <div class="flex flex-col gap-4">
        <button id="submenu-btn" class="flex items-center justify-between text-xl font-black text-primary-900 uppercase">
          Dịch vụ
          <svg xmlns="http://www.w3.org/2000/svg" id="submenu-icon" class="h-6 w-6 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div id="submenu-content" class="hidden flex flex-col gap-3 pl-4 border-l-2 border-neutral-100">
          {services.map(service => (
            <a href={service.href} class="text-base font-medium text-gray-500 py-1">{service.name}</a>
          ))}
        </div>
      </div>

      <a href="/du-an" class="text-xl font-black text-primary-900 uppercase">Dự án</a>
      <a href="/lien-he" class="text-xl font-black text-primary-900 uppercase">Liên hệ</a>
      
      <div class="mt-auto py-8 text-center border-t border-neutral-100">
        <p class="text-xs font-bold text-gray-400 uppercase mb-2">Hotline hỗ trợ 24/7</p>
        <a href="tel:086677040" class="text-3xl font-black text-primary-600">0866-77040</a>
      </div>
    </div>
  </div>
</header>

<div class="h-20"></div>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  const submenuBtn = document.getElementById('submenu-btn');
  const submenuContent = document.getElementById('submenu-content');
  const submenuIcon = document.getElementById('submenu-icon');

  // Đóng mở Menu chính Mobile
  menuBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', isHidden);
    // Khóa cuộn trang khi mở menu
    document.body.style.overflow = isHidden ? 'auto' : 'hidden';
  });

  // Đóng mở Menu phụ (Dịch vụ) Mobile
  submenuBtn?.addEventListener('click', () => {
    const isSubHidden = submenuContent?.classList.toggle('hidden');
    submenuIcon?.classList.toggle('rotate-180', !isSubHidden);
  });
</script>
