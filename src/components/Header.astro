---
// Header.astro
---

<header class="fixed w-full z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <div class="flex-shrink-0">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl font-black text-primary-900 tracking-tighter">iDECAL</span>
        <span class="w-2 h-2 bg-accent-500 rounded-full"></span>
      </a>
    </div>

    <nav class="hidden lg:flex items-center gap-8">
      <a href="/" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">TRANG CHỦ</a>
      <a href="/gioi-thieu" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">GIỚI THIỆU</a>
      
      <div class="relative group">
        <button class="flex items-center gap-1 text-sm font-bold text-gray-700 group-hover:text-primary-600 transition-colors uppercase">
          Dịch vụ
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor font-bold"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-full -left-4 w-64 bg-white shadow-xl border border-gray-50 rounded-2xl py-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0">
          <a href="/dich-vu/decal-dan-kinh-van-phong" class="block px-6 py-2 text-sm font-medium text-gray-600 hover:bg-primary-50 hover:text-primary-600">Decal Dán Kính Văn Phòng</a>
          <a href="/dich-vu/phim-cach-nhiet" class="block px-6 py-2 text-sm font-medium text-gray-600 hover:bg-primary-50 hover:text-primary-600">Phim Cách Nhiệt Nhà Kính</a>
        </div>
      </div>

      <a href="/lien-he" class="text-sm font-bold text-gray-700 hover:text-primary-600 transition-colors">LIÊN HỆ</a>
    </nav>

    <div class="flex items-center gap-4">
      <a href="tel:086677040" class="hidden sm:flex items-center gap-2 bg-primary-50 text-primary-600 px-4 py-2 rounded-xl font-black text-sm border border-primary-100">
        0866-77040
      </a>
      
      <button id="menu-button" class="lg:hidden p-2 text-primary-900 focus:outline-none" aria-label="Toggle Menu">
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden bg-white border-b border-gray-100 overflow-hidden transition-all duration-300">
    <div class="px-6 py-6 flex flex-col gap-4">
      <a href="/" class="text-lg font-bold text-gray-700">TRANG CHỦ</a>
      <a href="/gioi-thieu" class="text-lg font-bold text-gray-700">GIỚI THIỆU</a>
      <div class="flex flex-col gap-2 pl-4 border-l-2 border-primary-100">
        <p class="text-xs font-black text-primary-400 uppercase tracking-widest">Dịch vụ</p>
        <a href="/dich-vu/decal-dan-kinh-van-phong" class="text-base font-medium text-gray-600">Decal Văn Phòng</a>
        <a href="/dich-vu/phim-cach-nhiet" class="text-base font-medium text-gray-600">Phim Cách Nhiệt</a>
      </div>
      <a href="/lien-he" class="text-lg font-bold text-gray-700">LIÊN HỆ</a>
      <a href="tel:086677040" class="flex justify-center items-center bg-primary-600 text-white py-4 rounded-2xl font-black mt-4">
        GỌI NGAY: 0866-77040
      </a>
    </div>
  </div>
</header>

<div class="h-20"></div>

<script>
  // Script xử lý đóng mở Menu
  const menuButton = document.getElementById('menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  menuButton?.addEventListener('click', () => {
    // 1. Toggle class 'hidden' để hiện/ẩn menu
    mobileMenu?.classList.toggle('hidden');
    
    // 2. Thay đổi icon từ Hamburger sang dấu X (Optional nhưng nên có)
    const isOpened = !mobileMenu?.classList.contains('hidden');
    if (isOpened) {
      menuIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />`;
    } else {
      menuIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />`;
    }
  });
</script>
