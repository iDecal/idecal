---
// Navbar.astro - iDecal Navigation Component
const navLinks = [
  { name: "Trang chủ", href: "/" },
  { name: "Giới thiệu", href: "/gioi-thieu" },
  { 
    name: "Dịch vụ", 
    href: "#",
    dropdown: [
      { name: "Thiết kế - In ấn - Thi công Decal", href: "/dich-vu-tron-goi", highlight: true }, 
      { name: "Phim Cách Nhiệt", href: "/phim-cach-nhiet" },
      { name: "Decal 3D Vân Sóng", href: "/decal-mo-3d-van-song" },
      { name: "Decal Cắt Chữ", href: "/cat-decal" },
      { name: "Decal Quảng Cáo", href: "/decal-quang-cao" },
      { name: "Film Dán Nội Thất", href: "/film-noi-that" },
      { name: "Decal Dán Kính Văn Phòng", href: "/decal-dan-kinh-van-phong" },
    ]
  },
  { name: "Công trình thực tế", href: "/du-an" },
  { name: "Blog Kiến Thức", href: "/blog" },
  { name: "Liên hệ", href: "/lien-he" },
];
---

<nav class="fixed w-full z-50 bg-white/95 backdrop-blur-md border-b border-slate-100 shadow-sm">
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center h-20">
      
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center group">
          <img 
            src="/images/idecal-logo.png" 
            alt="iDecal Logo" 
            class="h-12 w-auto object-contain group-hover:scale-105 transition-transform duration-300"
          />
        </a>
      </div>

      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          <div class="relative group py-8">
            <a 
              href={link.href} 
              class="text-[13px] font-bold text-slate-600 hover:text-primary uppercase tracking-widest transition-colors flex items-center gap-1"
            >
              {link.name}
              {link.dropdown && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-50 group-hover:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>

            {link.dropdown && (
              <div class="absolute top-[90%] left-0 w-72 bg-white shadow-2xl rounded-2xl border border-slate-100 p-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all transform translate-y-2 group-hover:translate-y-0">
                <div class="grid gap-1">
                  {link.dropdown.map((sub) => (
                    <a 
                      href={sub.href} 
                      class={`block px-4 py-3 text-sm rounded-xl transition-all font-medium ${sub.highlight ? 'bg-primary text-slate-950 font-bold mb-2 shadow-md shadow-primary/20' : 'text-slate-600 hover:bg-slate-50 hover:text-primary'}`}
                    >
                      {sub.name}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="hidden lg:flex items-center gap-4">
        <div class="flex flex-col items-end mr-2">
          <span class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">Hotline 24/7</span>
          <a href="tel:0866077040" class="text-sm font-black text-secondary tracking-wide font-mono hover:text-primary transition-colors">
            0866-077-040
          </a>
        </div>
        
        <a href="/lien-he" class="bg-slate-950 text-white px-10 py-4 rounded-2xl font-bold text-xs uppercase tracking-[0.15em] hover:bg-primary hover:text-slate-950 transition-all shadow-2xl shadow-slate-900/20 active:scale-95 border-2 border-transparent hover:border-primary">
          Tư vấn miễn phí
        </a>
      </div>

      <button id="menu-toggle" class="lg:hidden p-2 text-slate-900" aria-label="Open Menu">
        <div class="w-6 h-5 flex flex-col justify-between">
          <span class="w-full h-0.5 bg-current rounded-full"></span>
          <span class="w-3/4 h-0.5 bg-current rounded-full ml-auto"></span>
          <span class="w-full h-0.5 bg-current rounded-full"></span>
        </div>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-white z-[60] transform translate-x-full transition-transform duration-500 lg:hidden flex flex-col">
    <div class="p-6 flex justify-between items-center border-b border-slate-100">
      <img src="/images/idecal-logo.png" alt="iDecal Logo" class="h-10 w-auto" />
      <button id="menu-close" class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center text-slate-900 text-3xl">&times;</button>
    </div>
    
    <div class="flex-1 overflow-y-auto p-8 space-y-10">
      {navLinks.map((link) => (
        <div class="space-y-5">
          <a href={link.href} class="text-3xl font-black text-slate-900 hover:text-primary transition-colors inline-block">{link.name}</a>
          {link.dropdown && (
            <div class="grid gap-5 ml-4 border-l-2 border-slate-100 pl-6">
              {link.dropdown.map((sub) => (
                <a href={sub.href} class={`text-lg font-bold ${sub.highlight ? 'text-primary uppercase' : 'text-slate-400'}`}>
                  {sub.name}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="p-6 border-t border-slate-100 space-y-4 bg-slate-50">
      <a href="tel:0866077040" class="w-full block bg-primary text-slate-950 text-center py-6 rounded-2xl font-black uppercase tracking-widest text-lg shadow-xl shadow-primary/30">
        Tư vấn: 0866-077-040
      </a>
      <p class="text-center text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em]">Khảo sát & Mang mẫu tận nhà trong 30p</p>
    </div>
  </div>
</nav>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';
  });

  menuClose?.addEventListener('click', () => {
    mobileMenu?.classList.add('translate-x-full');
    document.body.style.overflow = ''; 
  });
</script>
